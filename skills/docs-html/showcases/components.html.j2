{# type-name: Component Catalog #}
{# title: The Design System, Exercised #}
{# One of the showcases in showcases/. Regenerate every showcase with:
     python builder.py showcase
   which composes each showcases/<name>.html.j2 into showcases/<name>.html.
   This one — components.html — is the category-driven gallery: structured by
   the nine component categories (components/<category>/). Each category opens
   with a separator band, and every component sits under a specimen header
   pairing a human title with its macro/folder name. Exercises the real macros,
   so the gallery can never drift from the fragments. Open the composed
   showcases/components.html in a browser after ANY change to css/ or js/ —
   those changes hit all documents.

   Gallery-only chrome lives in this page's own {% raw %}{% block head %}{% endraw %} <style>
   below (gx- namespace) — NOT in a shared css/ module, because it styles this
   one page only. The macros:
     cat(dir, kicker, name)  — the category separator band; `dir` is the category
                              folder name (shown in parentheses after the title,
                              and the section id). The blurb is NOT passed — it
                              is looked up from `cat_blurb[dir]`, sourced from
                              components/<dir>/usage.md by the builder (single
                              source, shared with CATALOG.md).
     spec(title, name)              — the per-component specimen header.
   Documents never use either. #}
{% extends "doc-types/base.html.j2" %}

{% block head %}
<script>
  /* Gallery asset strategy (this page only — documents stay CDN-only).
     base.html.j2 links the LOCAL working-tree assets (../css, ../js), so the
     gallery previews the CURRENT tree; served from the CDN, those relative
     paths resolve inside the same pinned tag. If the local assets are absent
     (e.g. this file was copied out of the repo), fall back to the pinned CDN so
     the page still renders. Local first, CDN only if local is missing. */
  (function () {
    var CDN = "{{ cdn_fallback }}";
    function cssLoaded() {
      try {
        for (var i = 0; i < document.styleSheets.length; i++) {
          var s = document.styleSheets[i];
          if (s.href && /\/css\/docs-html\.css(\?|$)/.test(s.href) && s.cssRules && s.cssRules.length) return true;
        }
      } catch (e) { return true; }   /* cross-origin sheet already loaded → fine */
      return false;
    }
    /* The local loader defines docsHtml asynchronously (it injects the module
       scripts), so it can appear a beat AFTER DOMContentLoaded — poll for up to
       ~3.6s before deciding local is truly absent, or we'd double-load. */
    var tries = 0;
    function check() {
      if (cssLoaded() && window.docsHtml) return;          // local is fine
      if (++tries < 12) { setTimeout(check, 300); return; } // give it more time
      if (!cssLoaded()) {                                   // give up → CDN fallback
        var l = document.createElement("link");
        l.rel = "stylesheet"; l.href = CDN + "/css/docs-html.css";
        document.head.appendChild(l);
      }
      if (!window.docsHtml) {
        var sc = document.createElement("script");
        sc.src = CDN + "/js/docs-html.js"; sc.defer = true;
        document.head.appendChild(sc);
      }
    }
    document.addEventListener("DOMContentLoaded", check);
  })();
</script>
<style>
  /* -------------------------------------------------------------------------
     showcase chrome (gx- namespace) — page-local styles for THIS page only.
     Kept in the page, not in a shared css/ module: page-specific CSS belongs
     with its page. Documents never use these classes. Sits after the design
     system link, so it reads the same tokens (--accent, --border, …).
     ------------------------------------------------------------------------- */

  /* Hero — the sales opener replacing the plain metadata cover. */
  .gx-hero { margin: 0 0 1.5rem; padding-bottom: 1.1rem; border-bottom: 2px solid var(--border); }
  .gx-hero-kicker {
    font-family: var(--font-mono); font-size: .72rem; letter-spacing: .14em;
    text-transform: uppercase; color: var(--accent); font-weight: 600;
  }
  .gx-hero-title { font-size: 2rem; line-height: 1.1; margin: .4rem 0 0; border: 0; padding: 0; }
  .gx-hero-sub { margin: .6rem 0 0; color: var(--fg-soft); max-width: 64ch; font-size: 1.02rem; }

  /* Category separator band. */
  .gx-cat { margin: 2.6rem 0 1.2rem; }
  .gx-cat:first-of-type { margin-top: 1.4rem; }
  .gx-cat-kicker {
    font-family: var(--font-mono); font-size: .7rem; letter-spacing: .12em;
    text-transform: uppercase; color: var(--accent); font-weight: 600;
  }
  .gx-cat-name { font-size: 1.5rem; font-weight: 700; line-height: 1.1; margin: .15rem 0 0; border: 0; padding: 0; }
  .gx-cat-dir { font-family: var(--font-mono); font-size: .72rem; font-weight: 600; color: var(--accent); }
  .gx-cat-blurb { margin: .35rem 0 0; color: var(--fg-soft); max-width: 62ch; }
  .gx-cat-rule { height: 2px; margin-top: .75rem; border-radius: 2px; background: linear-gradient(90deg, var(--accent), transparent); }

  /* Per-component specimen header: title on the left, folder name chip on the right. */
  .gx-spec-head {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: .7rem; margin: var(--block-gap) 0 .55rem; padding-bottom: .3rem;
    border-bottom: 1px dashed var(--border);
  }
  .gx-spec-title { font-size: .98rem; font-weight: 600; margin: 0; border: 0; padding: 0; }
  .gx-spec-name {
    font-family: var(--font-mono); font-size: .72rem; font-weight: 600;
    color: var(--accent); background: var(--accent-soft);
    border: 1px solid var(--border); padding: .12rem .55rem; border-radius: 4px;
    white-space: nowrap;
  }
</style>
{% endblock %}

{% macro cat(dir, kicker, name) %}
  <section class="gx-cat" id="{{ dir }}">
    <div class="gx-cat-kicker">{{ kicker }}</div>
    <h2 class="gx-cat-name">{{ name }} <span class="gx-cat-dir">({{ dir }})</span></h2>
    <p class="gx-cat-blurb">{{ cat_blurb[dir] }}</p>
    <div class="gx-cat-rule"></div>
  </section>
{% endmacro %}

{% macro spec(title, name) %}
  <div class="gx-spec-head">
    <h3 class="gx-spec-title">{{ title }}</h3>
    <span class="gx-spec-name">{{ name }}</span>
  </div>
{% endmacro %}

{% block cover %}
<header class="gx-hero">
  <div class="gx-hero-kicker">docs-html · component catalog</div>
  <h1 class="gx-hero-title">{{ title }}</h1>
  <p class="gx-hero-sub">Every component, grouped by category — the building
    blocks for professional documents that ship as clean, hand-editable HTML,
    wired up with a single stylesheet and a single script.</p>
</header>
{% endblock %}

