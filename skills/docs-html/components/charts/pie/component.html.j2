{# purpose: composition of a single whole — a donut, for a handful of parts #}
{# sample: slices=[("A",50),("B",30),("C",20)], caption="s" #}
{% import "components/charts/_render.html.j2" as r %}

{% macro pie(slices=[], caption="", height=320, note="", donut=True) %}
{# Built as data and serialised once — see the note in line/component.html.j2. #}
{% set data = [] %}
{% for name, value in slices %}
{%   set _ = data.append({"name": name, "value": value}) %}
{% endfor %}
{# A donut by default: the hole costs nothing and stops the eye reading the
   whole disc as a quantity. The border separates adjacent slices without a
   second colour doing the work. #}
{% set option = {
     "tooltip": {"trigger": "item"},
     "series": [{"type": "pie",
                 "radius": (["42%", "70%"] if donut else "68%"),
                 "itemStyle": {"borderWidth": 2},
                 "data": data}],
   } %}
{% if caption %}
{%   set _ = option.update({"title": {"text": caption}}) %}
{% endif %}
{# Every slice is a separate colour, so the legend is not optional here. #}
{% set _ = option.update({"legend": {}}) %}
{{ r.out(option, height, note) }}
{% endmacro %}
