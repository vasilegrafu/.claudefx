{# Shared tail for every chart component: title the chart, reserve room for that
   title, hand the option to the engine, and print the reading beneath it.

   NOT a component — the file is not named component.html.j2, so the builder
   never registers it and it never appears in CATALOG.md. It exists so that
   twenty-one chart macros do not each repeat this, and so a second engine
   changes one line rather than twenty-one.

   It owns the TITLE on purpose. When each component set its own title and then
   separately guessed its own top margin, the two drifted: sixteen charts
   repeated `(52 if caption else 16)` while sankey pinned its series at 14 and
   drew the title straight through the ribbons. One owner, one rule, and a new
   chart cannot get it wrong by copying the wrong neighbour. #}
{% import "components/charts/apache-echarts/component.html.j2" as engine %}

{% macro out(option, height=340, note="", caption="", unit="") %}
{# The unit is a SUBTEXT line under the caption, not part of it. The registered
   theme already styles `title.subtextStyle` in the theme's muted tone, so it
   reads as metadata rather than as a second heading. Every chart takes it —
   including the ones with no axis to hang a label on, which is exactly why an
   axis name was never enough. #}
{% if caption or unit %}
{%   set title = {"text": caption} %}
{%   if unit %}{% set _ = title.update({"subtext": unit}) %}{% endif %}
{%   set _ = option.update({"title": title}) %}
{% endif %}
{# Clearance, derived rather than restated. A caption alone still yields 52 —
   the value the axis charts already used — so nothing that lays out correctly
   today moves. #}
{% set top = 16 + (36 if caption else 0) + (18 if unit else 0)
             + (24 if option.legend is defined else 0) %}
{# The legend defaults to top-centre — exactly where the title sits — so with
   both present they overprint. That is the same bug as the title clearance and
   it belongs to the same owner: push the keys below the title, once, for every
   chart that has a legend. #}
{% if option.legend is defined and caption %}
{%   set _ = option.legend.update({"top": 48 if unit else 30}) %}
{% endif %}
{% set kind = (option.series[0].type if option.series else "") %}
{# WHERE the clearance goes depends on the chart's shape, not its name. The
   axis charts have a grid; sankey, pie and funnel position their series
   directly; radar moves its centre; gauge owns its own layout entirely. #}
{% if option.grid is defined %}
{# A chart may carry SEVERAL grids — price-history stacks a volume panel under
   the price panel. Only the first takes the clearance; the lower panel is
   anchored to the bottom and must not move. #}
{%   set panel = option.grid if option.grid is mapping else option.grid[0] %}
{%   set _ = panel.update({"top": top}) %}
{% elif kind in ("sankey", "pie", "funnel") %}
{%   set _ = option.series[0].update({"top": top}) %}
{% elif option.radar is defined or kind == "gauge" %}
{# A radial chart cannot take a top margin — it has a CENTRE. Put that centre
   in the middle of what is left below the title, derived from the height the
   component was given rather than guessed as a percentage. Two hand-tuned
   magic numbers used to live here, and the gauge had none at all, so its arc
   ran under its own caption. #}
{%   set centre = ((top + (height - top) / 2) / height * 100) | round | int %}
{%   if option.radar is defined %}
{%     set _ = option.radar.update({"center": ["50%", "%d%%" | format(centre)]}) %}
{%   else %}
{%     set _ = option.series[0].update({"center": ["50%", "%d%%" | format(centre)]}) %}
{%   endif %}
{% endif %}
{% call engine.apache_echarts(height=height) %}{{ option | tojson(indent=2) }}{% endcall %}
{% if note %}
  <p class="chart-note">{{ note }}</p>
{% endif %}
{% endmacro %}
