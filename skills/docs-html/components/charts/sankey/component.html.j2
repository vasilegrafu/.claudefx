{# purpose: flow decomposition — how a total splits, merges or converts across stages #}
{# unit: required — a ribbon is a bare number with no axis to label #}
{# nodes: list of (name, role) — role is source|stage|cost|retained #}
{# links: list of (source, target, value) — names must match nodes #}
{# sample: nodes=[("Revenue","source"),("Cost","cost"),("Net","retained")], links=[("Revenue","Cost",40),("Revenue","Net",60)], caption="s" #}
{% import "components/charts/_render.html.j2" as r %}

{% macro sankey(nodes=[], links=[], caption="", height=420, note="", label_room=150, unit="") %}
{% set roles = {"source": "palette:1", "stage": "token:muted",
                "cost": "token:caution", "retained": "token:positive"} %}
{# The spec is built as a DATA STRUCTURE and serialised once. Hand-written JSON
   in a template needs manual comma bookkeeping, and a missed comma fails
   silently — the chart simply never appears and the source box shows instead,
   which looks exactly like an unreachable CDN. #}
{% set node_data = [] %}
{% for name, role in nodes %}
{%   set _ = node_data.append({"name": name,
                               "itemStyle": {"color": roles.get(role, "token:muted")}}) %}
{% endfor %}
{% set link_data = [] %}
{% for source, target, value in links %}
{%   set _ = link_data.append({"source": source, "target": target, "value": value}) %}
{% endfor %}
{# Layout, not styling — it depends on how long the labels are, so it cannot
   live in the theme. `label_room` reserves right margin for the terminal
   nodes' labels, which sit OUTSIDE the node; without it they clip. The white
   text border keeps a label legible where it crosses a ribbon. #}
{% set option = {
     "tooltip": {"trigger": "item", "triggerOn": "mousemove"},
     "series": [{"type": "sankey", "emphasis": {"focus": "adjacency"},
                 "left": 8, "right": label_room, "top": 14, "bottom": 14,
                 "nodeWidth": 14, "nodeGap": 18, "nodeAlign": "left",
                 "draggable": false,
                 "label": {"fontSize": 12, "textBorderColor": "#ffffff",
                           "textBorderWidth": 3},
                 "data": node_data, "links": link_data}],
   } %}
{{ r.out(option, height, note, caption, unit) }}
{% endmacro %}
