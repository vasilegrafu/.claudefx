{# purpose: several series summed at each point, drawn as lines — the total and its parts #}
{# sample: series=[("A",[1,2,3]),("B",[3,2,1])], categories=["x","y","z"], caption="s" #}
{% import "components/charts/_render.html.j2" as r %}

{% macro stacked_line(series=[], categories=[], caption="", height=340, note="", y_name="") %}
{# Built as data and serialised once — see the note in line/component.html.j2. #}
{% set built = [] %}
{% for name, values in series %}
{# Every series shares one stack, so the TOP line is the total and each band is
   a part. Only the bottom series is read against the axis; the rest are read
   as thicknesses, which is the trade this kind makes. #}
{%   set _ = built.append({"type": "line", "name": name, "stack": "total",
                           "showSymbol": categories | length <= 24,
                           "data": values}) %}
{% endfor %}
{% set y_axis = {"type": "value"} %}
{% if y_name %}
{%   set _ = y_axis.update({"name": y_name, "nameLocation": "middle",
                            "nameGap": 46, "nameRotate": 90}) %}
{% endif %}
{% set option = {
     "tooltip": {"trigger": "axis", "axisPointer": {"type": "line"}},
     "grid": {"left": (46 if y_name else 8), "right": 16,
              "top": (52 if caption else 16), "bottom": 8, "containLabel": true},
     "xAxis": {"type": "category", "data": categories},
     "yAxis": y_axis,
     "series": built,
   } %}
{% if caption %}
{%   set _ = option.update({"title": {"text": caption}}) %}
{% endif %}
{% if built | length > 1 %}
{%   set _ = option.update({"legend": {}}) %}
{% endif %}
{{ r.out(option, height, note) }}
{% endmacro %}
