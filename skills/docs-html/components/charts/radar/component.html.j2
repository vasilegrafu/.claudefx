{# purpose: several attributes of a few entities at once — profile shape, not precise values #}
{# unit: none — normalised scores, a different scale per indicator #}
{# sample: indicators=[("a",None),("b",None),("c",None)], series=[("X",[1,2,3])], caption="s" #}
{% import "components/charts/_render.html.j2" as r %}

{% macro radar(indicators=[], series=[], caption="", height=380, note="", unit="") %}
{# `indicators` is [(name, max)]; pass max=None and it is DERIVED — the largest
   value observed on that axis across every series, plus 15% headroom.

   This is computed rather than left to the caller on purpose. A radar with
   per-axis maxima chosen by hand draws whatever shape you like: the same data
   can be made to look balanced or lopsided purely by the choice of scale. #}
{% set built_ind = [] %}
{% for name, maximum in indicators %}
{%   set axis = loop.index0 %}
{%   set ns = namespace(observed=0) %}
{%   for entity, values in series %}
{%     if values[axis] > ns.observed %}
{%       set ns.observed = values[axis] %}
{%     endif %}
{%   endfor %}
{%   set _ = built_ind.append({"name": name,
                               "max": maximum if maximum is not none
                                      else (ns.observed * 1.15) | round(2)}) %}
{% endfor %}
{% set data = [] %}
{% for name, values in series %}
{%   set _ = data.append({"name": name, "value": values}) %}
{% endfor %}
{# The plot is pulled down and in: at full size the topmost indicator label
   collides with the title and the legend, which both sit at the top of the
   card. #}
{% set option = {
     "tooltip": {"trigger": "item"},
     "radar": {"indicator": built_ind, "radius": "62%",
               "center": ["50%", ("58%" if caption else "52%")]},
     "series": [{"type": "radar", "data": data}],
   } %}
{% if series | length > 1 %}
{%   set _ = option.update({"legend": {}}) %}
{% endif %}
{{ r.out(option, height, note, caption, unit) }}
{% endmacro %}
