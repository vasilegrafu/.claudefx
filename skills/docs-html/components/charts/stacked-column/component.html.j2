{# purpose: parts summing to a whole across categories — vertical stacked bars #}
{# unit: axis — one measured axis; name it with y_name #}
{# sample: series=[("A",[1,2,3]),("B",[3,2,1])], categories=["x","y","z"], caption="s" #}
{% import "components/charts/_render.html.j2" as r %}

{% macro stacked_column(series=[], categories=[], caption="", height=340, note="", y_name="", unit="") %}
{# Built as data and serialised once — see the note in line/component.html.j2. #}
{% set built = [] %}
{% for name, values in series %}
{# One shared stack, so each column's height is the category total and each
   segment is a part. Only the bottom segment sits on the axis; the others are
   compared as lengths, so put the series that matters most at the bottom. #}
{%   set _ = built.append({"type": "bar", "name": name, "stack": "total",
                           "data": values}) %}
{% endfor %}
{% set y_axis = {"type": "value"} %}
{% if y_name %}
{%   set _ = y_axis.update({"name": y_name, "nameLocation": "middle",
                            "nameGap": 46, "nameRotate": 90}) %}
{% endif %}
{% set option = {
     "tooltip": {"trigger": "axis", "axisPointer": {"type": "shadow"}},
     "grid": {"left": (46 if y_name else 8), "right": 16, "bottom": 8, "containLabel": true},
     "xAxis": {"type": "category", "data": categories},
     "yAxis": y_axis,
     "series": built,
   } %}
{% if built | length > 1 %}
{%   set _ = option.update({"legend": {}}) %}
{% endif %}
{{ r.out(option, height, note, caption, unit) }}
{% endmacro %}
