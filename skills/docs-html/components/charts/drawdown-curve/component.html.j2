{# purpose: peak-to-trough decline over time — the shape of the losing periods, not the gains #}
{# series: list of (date, value) — the macro derives the running peak and the drawdown #}
{# sample: series=[("a",100),("b",120),("c",90)], caption="s" #}
{% import "components/charts/apache-echarts/component.html.j2" as engine %}

{% macro drawdown_curve(series=[], caption="", height=300, note="") %}
{# Drawdown is computed HERE, at compose time: the document carries the level
   series it was given, and the arithmetic that turned it into a decline is
   auditable in the rendered spec rather than hidden in a script. #}
{% set ns = namespace(peak=none, trough=0) %}
{% set dates = [] %}{% set values = [] %}
{% for date, value in series %}
{%   if ns.peak is none or value > ns.peak %}{% set ns.peak = value %}{% endif %}
{%   set dd = (100 * (value - ns.peak) / ns.peak) | round(2) %}
{%   if dd < ns.trough %}{% set ns.trough = dd %}{% endif %}
{%   set _ = dates.append(date) %}{% set _ = values.append(dd) %}
{% endfor %}
{# `left` is wide enough to hold the rotated axis name: containLabel reserves
   room for tick labels but not for the name, which would otherwise clip. The
   name sits mid-axis because ECharts puts it at the end — into the title.
   The markPoint pin must hold the full signed value ("-18.75"); at the default
   size it truncates, and a marker showing a wrong number is worse than none. #}
{% set option = {
     "tooltip": {"trigger": "axis"},
     "grid": {"left": 42, "right": 16, "top": (52 if caption else 16),
              "bottom": 8, "containLabel": true},
     "xAxis": {"type": "category", "data": dates},
     "yAxis": {"type": "value", "max": 0, "name": "drawdown %",
               "nameLocation": "middle", "nameGap": 46, "nameRotate": 90},
     "series": [{
       "type": "line", "name": "drawdown", "showSymbol": false,
       "lineStyle": {"color": "token:negative", "width": 1.5},
       "areaStyle": {"color": "token:negative", "opacity": 0.14},
       "markPoint": {"symbol": "circle", "symbolSize": 46,
                     "itemStyle": {"color": "token:negative"},
                     "label": {"fontSize": 10, "offset": [0, 0]},
                     "data": [{"type": "min", "name": "max drawdown"}]},
       "data": values}],
   } %}
{% if caption %}{% set _ = option.update({"title": {"text": caption}}) %}{% endif %}
{% call engine.apache_echarts(height=height) %}{{ option | tojson(indent=2) }}{% endcall %}
{% if note %}
  <p class="chart-note">{{ note }}</p>
{% else %}
  <p class="chart-note">Maximum drawdown {{ ns.trough }}%.</p>
{% endif %}
{% endmacro %}
