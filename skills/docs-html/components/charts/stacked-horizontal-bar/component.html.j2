{# purpose: parts summing to a whole, laid on their side — for long category names #}
{# unit: axis — one measured axis (horizontal); y_name names it #}
{# sample: series=[("A",[1,2,3]),("B",[3,2,1])], categories=["x","y","z"], caption="s" #}
{% import "components/charts/_render.html.j2" as r %}

{% macro stacked_horizontal_bar(series=[], categories=[], caption="", height=340, note="", y_name="", unit="") %}
{# Built as data and serialised once — see the note in line/component.html.j2. #}
{% set built = [] %}
{% for name, values in series %}
{%   set _ = built.append({"type": "bar", "name": name, "stack": "total",
                           "data": values}) %}
{% endfor %}
{# The axes are swapped, so `y_name` names the HORIZONTAL value axis. It must
   not be rotated — a rotated name on a horizontal axis reads sideways — and
   the bottom margin widens instead of the left. #}
{% set value_axis = {"type": "value"} %}
{% if y_name %}
{%   set _ = value_axis.update({"name": y_name, "nameLocation": "middle",
                                "nameGap": 28}) %}
{% endif %}
{# Without `inverse` the FIRST category lands at the bottom and the whole
   ranking reads upside-down. A horizontal bar chart is read top-to-bottom. #}
{% set option = {
     "tooltip": {"trigger": "axis", "axisPointer": {"type": "shadow"}},
     "grid": {"left": 8, "right": 16,
              "bottom": (34 if y_name else 8), "containLabel": true},
     "xAxis": value_axis,
     "yAxis": {"type": "category", "data": categories, "inverse": true},
     "series": built,
   } %}
{% if built | length > 1 %}
{%   set _ = option.update({"legend": {}}) %}
{% endif %}
{{ r.out(option, height, note, caption, unit) }}
{% endmacro %}
