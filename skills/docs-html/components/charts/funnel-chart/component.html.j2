{# purpose: stage-to-stage narrowing — a rendered funnel with proportional bands #}
{# sample: stages=[("A",100),("B",60),("C",30)], caption="s" #}
{% import "components/charts/_render.html.j2" as r %}

{% macro funnel_chart(stages=[], caption="", height=340, note="") %}
{# Built as data and serialised once — see the note in line/component.html.j2. #}
{% set data = [] %}
{% for name, value in stages %}
{%   set _ = data.append({"name": name, "value": value}) %}
{% endfor %}
{# `sort: descending` is what makes the shape a funnel rather than an arbitrary
   stack of bands. Labels sit inside because the band width already encodes the
   value and the reader still needs the number. #}
{% set option = {
     "tooltip": {"trigger": "item"},
     "series": [{"type": "funnel", "left": "12%", "right": "12%",
                 "sort": "descending", "gap": 2,
                 "label": {"show": true, "position": "inside"},
                 "data": data}],
   } %}
{% if caption %}
{%   set _ = option.update({"title": {"text": caption}}) %}
{% endif %}
{% set _ = option.update({"legend": {}}) %}
{{ r.out(option, height, note) }}
{% endmacro %}
