{# purpose: labeled progress/target bar #}
{# pct computed at compose time; carried as a data- attribute (no style=) #}
{% macro meter(label="", value=0, max=100, display="") %}
  <div class="meter">
    <div class="meter-head">
      <span class="meter-label">{{ label }}</span>
      <span class="meter-value">{{ display if display else value }}</span>
    </div>
    <div class="meter-track"><div class="meter-fill" data-pct="{{ ((100 * value / max) if max else 0) | round(1) }}%"></div></div>
  </div>
{% endmacro %}
