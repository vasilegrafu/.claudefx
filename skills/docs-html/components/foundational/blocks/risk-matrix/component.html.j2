{# purpose: 5x5 probability-by-impact heat grid of risks #}
{# items: list of (id, probability 1-5, impact 1-5, label) #}
{% macro risk_matrix(items=[]) %}
  <div class="risk-matrix" role="img" aria-label="probability by impact risk matrix">
    <span class="rm-corner">P \ I</span>
  {% for i in range(1, 6) %}
    <span class="rm-axis">{{ i }}</span>
  {% endfor %}
  {% for p in range(5, 0, -1) %}
    <span class="rm-axis">{{ p }}</span>
    {% for i in range(1, 6) %}
      {% set score = p * i %}
      <span class="rm-cell {{ 'rm-high' if score > 12 else ('rm-med' if score > 4 else 'rm-low') }}">
      {% for id, prob, impact, label in items %}{% if prob == p and impact == i %}<span class="rm-chip" title="{{ label }}">{{ id }}</span>{% endif %}{% endfor %}
      </span>
    {% endfor %}
  {% endfor %}
  </div>
{% endmacro %}
