{# purpose: feature yes/no/partial comparison grid #}
{# cells: "yes" | "no" | "part" render as marks; anything else renders as text #}
{% macro comparison_table(headers=[], rows=[]) %}
  <table class="comparison">
    <thead><tr>{% for h in headers %}<th>{{ h }}</th>{% endfor %}</tr></thead>
    <tbody>
    {% for row in rows %}
      <tr>
      {% for cell in row %}
        {% if cell == "yes" %}<td><span class="mark-yes">✓</span></td>
        {% elif cell == "no" %}<td><span class="mark-no">✗</span></td>
        {% elif cell == "part" %}<td><span class="mark-part">◐</span></td>
        {% else %}<td>{{ cell }}</td>
        {% endif %}
      {% endfor %}
      </tr>
    {% endfor %}
    </tbody>
  </table>
{% endmacro %}
