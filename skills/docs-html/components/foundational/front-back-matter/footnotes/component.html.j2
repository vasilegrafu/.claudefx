{# purpose: numbered footnotes list with back-links #}
{# notes render numbered; pair each with an inline
   <sup class="fn"><a id="fnref-N" href="#fn-N">N</a></sup> in the prose #}
{% macro footnotes(notes=[]) %}
  <ol class="footnotes">
  {% for note in notes %}
    <li id="fn-{{ loop.index }}">{{ note }} <a class="fn-back" href="#fnref-{{ loop.index }}" aria-label="back to text">↩</a></li>
  {% endfor %}
  </ol>
{% endmacro %}
