{# purpose: two-column pros vs cons list #}
{% macro pros_cons(pros=[], cons=[]) %}
  <div class="business-pros-cons">
    <div class="business-pros">
      <p>Pros</p>
      <ul>{% for item in pros %}<li>{{ item }}</li>{% endfor %}</ul>
    </div>
    <div class="business-cons">
      <p>Cons</p>
      <ul>{% for item in cons %}<li>{{ item }}</li>{% endfor %}</ul>
    </div>
  </div>
{% endmacro %}
