{# purpose: 2x2 strengths/weaknesses/opportunities/threats grid #}
{% macro swot_grid(strengths=[], weaknesses=[], opportunities=[], threats=[]) %}
  <div class="business-swot">
    <div class="business-strengths"><p>Strengths</p><ul>{% for i in strengths %}<li>{{ i }}</li>{% endfor %}</ul></div>
    <div class="business-weaknesses"><p>Weaknesses</p><ul>{% for i in weaknesses %}<li>{{ i }}</li>{% endfor %}</ul></div>
    <div class="business-opportunities"><p>Opportunities</p><ul>{% for i in opportunities %}<li>{{ i }}</li>{% endfor %}</ul></div>
    <div class="business-threats"><p>Threats</p><ul>{% for i in threats %}<li>{{ i }}</li>{% endfor %}</ul></div>
  </div>
{% endmacro %}
