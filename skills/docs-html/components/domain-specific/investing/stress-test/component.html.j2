{# purpose: portfolio or company impact under named stress scenarios #}
{# rows: list of (scenario, trigger, impact, magnitude, tone, response) — magnitude is a number in percent for the bar #}
{% macro stress_test(rows=[], caption="", note="") %}
  <table class="investing-fin investing-stress">
  {% if caption %}<caption>{{ caption }}</caption>{% endif %}
    <thead><tr><th>Scenario</th><th>Trigger</th><th class="investing-stress-impact-head">Impact</th><th>Response</th></tr></thead>
    <tbody>
    {% for scenario, trigger, impact, magnitude, tone, response in rows %}
      <tr>
        <th scope="row">{{ scenario }}</th>
        <td class="investing-stress-trigger">{{ trigger }}</td>
        <td class="investing-stress-impact">
          <span class="investing-stress-value investing-tone-{{ tone }}">{{ impact }}</span>
          <span class="investing-stress-track"><span class="investing-stress-fill investing-stress-fill-{{ tone }}" data-pct="{{ magnitude }}%"></span></span>
        </td>
        <td class="investing-stress-response">{{ response }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% if note %}<p class="investing-st-source">{{ note }}</p>{% endif %}
{% endmacro %}
