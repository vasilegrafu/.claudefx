{# purpose: the subject against named peers across chosen metrics, subject row highlighted #}
{# rows: list of (name, cells, subject) — subject true marks the company under analysis #}
{% macro peer_comparison(headers=[], rows=[], caption="") %}
  <table class="investing-fin investing-peers">
  {% if caption %}<caption>{{ caption }}</caption>{% endif %}
    <thead><tr><th>Company</th>{% for h in headers %}<th>{{ h }}</th>{% endfor %}</tr></thead>
    <tbody>
    {% for name, cells, subject in rows %}
      <tr{% if subject %} class="investing-subject"{% endif %}>
        <th scope="row">{{ name }}</th>
        {% for v in cells %}<td>{{ v }}</td>{% endfor %}
      </tr>
    {% endfor %}
    </tbody>
  </table>
{% endmacro %}
