{# purpose: movement schedule: opening balance, the movements, closing balance #}
{# rows: list of (label, values, kind) — kind opening|movement|closing #}
{% macro roll_forward(periods=[], rows=[], caption="", unit="", note="") %}
  <table class="investing-fin investing-rollfwd">
  {% if caption or unit %}<caption>{{ caption }}{% if unit %} <span class="investing-st-unit">{{ unit }}</span>{% endif %}</caption>{% endif %}
    <thead><tr><th>{{ "" }}</th>{% for p in periods %}<th>{{ p }}</th>{% endfor %}</tr></thead>
    <tbody>
    {% for label, values, kind in rows %}
      <tr class="investing-rf-{{ kind if kind else 'movement' }}">
        <th scope="row">{{ label }}</th>
        {% for v in values %}<td{% if v is string and (v.startswith("(") or v.startswith("-") or v.startswith("−")) %} class="neg"{% endif %}>{{ v }}</td>{% endfor %}
        {% for _ in range(periods | length - values | length) %}<td></td>{% endfor %}
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% if note %}<p class="investing-st-source">{{ note }}</p>{% endif %}
{% endmacro %}
