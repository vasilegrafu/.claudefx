{# purpose: discounted cash flow build: projected flows, terminal value, enterprise and equity value #}
{# rows use the statement grammar: (label, values, kind, note); assumptions: list of (label, value) #}
{% macro dcf_summary(periods=[], rows=[], assumptions=[], caption="", unit="", note="") %}
  {% if assumptions %}
  <dl class="investing-dcf-assumptions">
    {% for label, value in assumptions %}
    <div><dt>{{ label }}</dt><dd>{{ value }}</dd></div>
    {% endfor %}
  </dl>
  {% endif %}
  <table class="investing-fin investing-statement st-dcf">
  {% if caption or unit %}<caption>{{ caption }}{% if unit %} <span class="investing-st-unit">{{ unit }}</span>{% endif %}</caption>{% endif %}
    <thead><tr><th>{{ "" }}</th>{% for p in periods %}<th>{{ p }}</th>{% endfor %}</tr></thead>
    <tbody>
    {% for label, values, kind, note_ref in rows %}
      <tr class="investing-st-{{ kind if kind else 'line' }}">
        <th scope="row">{{ label }}{% if note_ref %} <a class="investing-st-note" href="#note-{{ note_ref }}">{{ note_ref }}</a>{% endif %}</th>
        {% for v in values %}<td{% if v is string and (v.startswith("(") or v.startswith("-") or v.startswith("−")) %} class="neg"{% endif %}>{{ v }}</td>{% endfor %}
        {% for _ in range(periods | length - values | length) %}<td></td>{% endfor %}
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% if note %}<p class="investing-st-source">{{ note }}</p>{% endif %}
{% endmacro %}
