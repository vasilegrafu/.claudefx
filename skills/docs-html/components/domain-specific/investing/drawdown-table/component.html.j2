{# purpose: the worst drawdowns with peak, trough, recovery and how long each took #}
{# rows: list of (depth, peak, trough, recovery, decline_months, recovery_months, cause) #}
{% macro drawdown_table(rows=[], caption="", note="") %}
  <table class="investing-fin investing-drawdowns">
  {% if caption %}<caption>{{ caption }}</caption>{% endif %}
    <thead><tr><th>#</th><th>Depth</th><th>Peak</th><th>Trough</th><th>Recovered</th><th>Fall</th><th>Recovery</th><th>Cause</th></tr></thead>
    <tbody>
    {% for depth, peak, trough, recovery, decline_months, recovery_months, cause in rows %}
      <tr>
        <th scope="row">{{ loop.index }}</th>
        <td class="investing-dd-depth neg">{{ depth }}</td>
        <td class="investing-dd-date">{{ peak }}</td>
        <td class="investing-dd-date">{{ trough }}</td>
        <td class="investing-dd-date">{{ recovery }}</td>
        <td>{{ decline_months }}</td>
        <td>{{ recovery_months }}</td>
        <td class="investing-dd-cause">{{ cause }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% if note %}<p class="investing-st-source">{{ note }}</p>{% endif %}
{% endmacro %}
