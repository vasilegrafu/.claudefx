{# purpose: nested magnitudes narrowing to a target — market sizing, or a conversion funnel #}
{# stages: list of (label, value, pct, note) — pct is the stage width relative to the first stage #}
{% macro funnel(stages=[], caption="", note="") %}
  <figure class="investing-funnel">
  {% if caption %}<figcaption>{{ caption }}</figcaption>{% endif %}
    <div class="investing-funnel-stages">
    {% for label, value, pct, stage_note in stages %}
      <div class="investing-funnel-stage">
        <span class="investing-funnel-bar" data-pct="{{ pct }}%">
          <span class="investing-funnel-label">{{ label }}</span>
          <span class="investing-funnel-value">{{ value }}</span>
        </span>
        {% if stage_note %}<span class="investing-funnel-note">{{ stage_note }}</span>{% endif %}
      </div>
    {% endfor %}
    </div>
    {% if note %}<p class="investing-funnel-summary">{{ note }}</p>{% endif %}
  </figure>
{% endmacro %}
