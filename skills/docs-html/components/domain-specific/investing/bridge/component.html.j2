{# purpose: waterfall bridge decomposing how a total moved from one value to another #}
{# steps: list of (label, delta, kind, display) — kind start|up|down|subtotal|end; delta is numeric, display is the text #}
{% macro bridge(steps=[], scale_min=0, scale_max=100, caption="", note="") %}
  {% set span = (scale_max - scale_min) if (scale_max - scale_min) else 1 %}
  {% set ns = namespace(cum=scale_min) %}
  <figure class="investing-bridge">
  {% if caption %}<figcaption>{{ caption }}</figcaption>{% endif %}
    <div class="investing-bridge-rows">
    {% for label, delta, kind, display in steps %}
      {% if kind in ("start", "end", "subtotal") %}
        {% set lo = scale_min %}{% set hi = delta %}{% set ns.cum = delta %}
      {% elif delta >= 0 %}
        {% set lo = ns.cum %}{% set hi = ns.cum + delta %}{% set ns.cum = ns.cum + delta %}
      {% else %}
        {% set lo = ns.cum + delta %}{% set hi = ns.cum %}{% set ns.cum = ns.cum + delta %}
      {% endif %}
      <div class="investing-bridge-row investing-bridge-{{ kind }}">
        <span class="investing-bridge-label">{{ label }}</span>
        <span class="investing-bridge-track">
          <span class="investing-bridge-bar" data-lo="{{ (100 * (lo - scale_min) / span) | round(2) }}%" data-span="{{ (100 * (hi - lo) / span) | round(2) }}%"></span>
        </span>
        <span class="investing-bridge-value">{{ display }}</span>
      </div>
    {% endfor %}
    </div>
    {% if note %}<p class="investing-bridge-note">{{ note }}</p>{% endif %}
  </figure>
{% endmacro %}
