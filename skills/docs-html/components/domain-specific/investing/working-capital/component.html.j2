{# purpose: working capital efficiency: days sales, inventory and payables, and the cash conversion cycle #}
{# rows: list of (metric, values, kind, dir) — kind ""|total; dir up|down|flat #}
{% macro working_capital(periods=[], rows=[], caption="", note="") %}
  <table class="investing-fin investing-workcap">
  {% if caption %}<caption>{{ caption }}</caption>{% endif %}
    <thead><tr><th>Metric</th>{% for p in periods %}<th>{{ p }}</th>{% endfor %}<th class="investing-trend-head">Trend</th></tr></thead>
    <tbody>
    {% for metric, values, kind, dir in rows %}
      <tr{% if kind %} class="investing-wc-{{ kind }}"{% endif %}>
        <th scope="row">{{ metric }}</th>
        {% for v in values %}<td{% if v is string and (v.startswith("(") or v.startswith("-") or v.startswith("−")) %} class="neg"{% endif %}>{{ v }}</td>{% endfor %}
        <td class="investing-trend investing-trend-{{ dir }}">{{ {"up": "▲", "down": "▼"}.get(dir, "▬") }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% if note %}<p class="investing-st-source">{{ note }}</p>{% endif %}
{% endmacro %}
