{# purpose: identity strip for the security under analysis: ticker, name, key market data #}
{# facts: list of (label, value) — price, market cap, sector, float, whatever the document needs #}
{% macro security_header(ticker="", name="", exchange="", asof="", facts=[]) %}
  <header class="investing-sec-header">
    <p class="investing-sec-id">
      <span class="investing-sec-ticker">{{ ticker }}</span>
      <span class="investing-sec-name">{{ name }}</span>
      {% if exchange %}<span class="investing-sec-exchange">{{ exchange }}</span>{% endif %}
    </p>
    {% if facts %}
    <dl class="investing-sec-facts">
      {% for label, value in facts %}
      <div><dt>{{ label }}</dt><dd>{{ value }}</dd></div>
      {% endfor %}
    </dl>
    {% endif %}
    {% if asof %}<p class="investing-sec-asof">Market data as of {{ asof }}</p>{% endif %}
  </header>
{% endmacro %}
