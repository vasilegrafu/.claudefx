{# purpose: probability-weighted scenarios with the expected value total #}
{# rows: list of (scenario, tone, probability, target, ret, weighted) — tone good|neutral|bad #}
{% macro expected_value(rows=[], total="", caption="") %}
  <table class="investing-fin investing-ev">
  {% if caption %}<caption>{{ caption }}</caption>{% endif %}
    <thead><tr><th>Scenario</th><th>Probability</th><th>Price target</th><th>Return</th><th>Weighted</th></tr></thead>
    <tbody>
    {% for scenario, tone, probability, target, ret, weighted in rows %}
      <tr>
        <th scope="row"><span class="investing-ev-dot investing-ev-{{ tone }}" aria-hidden="true"></span>{{ scenario }}</th>
        <td>{{ probability }}</td>
        <td>{{ target }}</td>
        <td>{{ ret }}</td>
        <td>{{ weighted }}</td>
      </tr>
    {% endfor %}
    </tbody>
    {% if total %}
    <tfoot><tr class="investing-total"><th scope="row">Expected value</th><td>100%</td><td></td><td></td><td>{{ total }}</td></tr></tfoot>
    {% endif %}
  </table>
{% endmacro %}
