{# purpose: the maturity wall: debt falling due by period, with coupon and share of total #}
{# items: list of (period, amount, share, rate, instrument) — share is a number in percent of total debt #}
{% macro debt_maturity(items=[], caption="", unit="", summary="") %}
  <figure class="investing-maturity">
  {% if caption or unit %}<figcaption>{{ caption }}{% if unit %} <span class="investing-st-unit">{{ unit }}</span>{% endif %}</figcaption>{% endif %}
    <div class="investing-maturity-rows">
    {% for period, amount, share, rate, instrument in items %}
      <div class="investing-maturity-row">
        <span class="investing-maturity-period">{{ period }}</span>
        <span class="investing-maturity-track"><span class="investing-maturity-fill" data-pct="{{ share }}%"></span></span>
        <span class="investing-maturity-amount">{{ amount }}</span>
        <span class="investing-maturity-rate">{{ rate }}</span>
        <span class="investing-maturity-instrument">{{ instrument }}</span>
      </div>
    {% endfor %}
    </div>
    {% if summary %}<p class="investing-maturity-summary">{{ summary }}</p>{% endif %}
  </figure>
{% endmacro %}
