{# purpose: risk and return statistics side by side with the benchmark #}
{# rows: list of (metric, value, benchmark, note) #}
{# subject_label names the column being measured — "Strategy" for a portfolio,
   the ticker for a single name. It was hardcoded while benchmark_label was not,
   which read wrongly the first time this was used in a single-stock thesis. #}
{% macro risk_metrics(rows=[], benchmark_label="Benchmark", caption="",
                      subject_label="Strategy") %}
  <table class="investing-fin investing-riskmetrics">
  {% if caption %}<caption>{{ caption }}</caption>{% endif %}
    <thead><tr><th>Metric</th><th>{{ subject_label }}</th><th>{{ benchmark_label }}</th><th>Reading</th></tr></thead>
    <tbody>
    {% for metric, value, benchmark, note in rows %}
      <tr>
        <th scope="row">{{ metric }}</th>
        <td class="investing-rm-value">{{ value }}</td>
        <td>{{ benchmark }}</td>
        <td class="investing-rm-note">{{ note }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
{% endmacro %}
