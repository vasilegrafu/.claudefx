{# purpose: the numbered accounting disclosures that statement lines cite, with the ones that matter flagged #}
{# items: list of (num, title, body, flag) — flag "" | watch; each note anchors at id="note-<num>" #}
{% macro footnote_disclosures(items=[], caption="") %}
  <div class="investing-disclosures">
  {% if caption %}<p class="investing-disclosures-caption">{{ caption }}</p>{% endif %}
  {% for num, title, body, flag in items %}
    <section class="investing-disclosure{% if flag %} investing-disclosure-{{ flag }}{% endif %}" id="note-{{ num }}">
      <p class="investing-disclosure-head">
        <span class="investing-disclosure-num">Note {{ num }}</span>
        <span class="investing-disclosure-title">{{ title }}</span>
        {% if flag %}<span class="investing-disclosure-flag">{{ flag }}</span>{% endif %}
      </p>
      <p class="investing-disclosure-body">{{ body }}</p>
    </section>
  {% endfor %}
  </div>
{% endmacro %}
