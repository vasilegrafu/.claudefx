{# purpose: 2x2 positioning map with items placed by two scores #}
{# items: list of (label, x, y, tone) — x and y are numbers 0..100; positions computed at compose time #}
{% macro quadrant_map(items=[], x_label="", y_label="", quadrants=[], caption="", note="") %}
  <figure class="investing-quadrant">
  {% if caption %}<figcaption>{{ caption }}</figcaption>{% endif %}
    <div class="investing-quadrant-frame">
      <span class="investing-quadrant-y-label">{{ y_label }}</span>
      <div class="investing-quadrant-plot">
        {% for q in quadrants %}<span class="investing-quadrant-zone investing-quadrant-z{{ loop.index }}">{{ q }}</span>{% endfor %}
        {% for label, x, y, tone in items %}
        <span class="investing-quadrant-item{% if tone %} investing-quadrant-{{ tone }}{% endif %}" data-x="{{ x }}%" data-y="{{ y }}%">
          <span class="investing-quadrant-dot"></span><span class="investing-quadrant-label">{{ label }}</span>
        </span>
        {% endfor %}
      </div>
      <span class="investing-quadrant-x-label">{{ x_label }}</span>
    </div>
    {% if note %}<p class="investing-quadrant-note">{{ note }}</p>{% endif %}
  </figure>
{% endmacro %}
