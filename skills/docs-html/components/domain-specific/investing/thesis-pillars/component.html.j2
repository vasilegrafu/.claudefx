{# purpose: the load-bearing arguments of a thesis: claim, evidence, and what would break it #}
{# items: list of (claim, evidence, falsifier) #}
{% macro thesis_pillars(items=[]) %}
  <ol class="investing-pillars">
  {% for claim, evidence, falsifier in items %}
    <li class="investing-pillar">
      <p class="investing-pillar-claim">{{ claim }}</p>
      {% if evidence %}<p class="investing-pillar-evidence">{{ evidence }}</p>{% endif %}
      {% if falsifier %}<p class="investing-pillar-falsifier"><span class="investing-pillar-tag">Breaks if</span> {{ falsifier }}</p>{% endif %}
    </li>
  {% endfor %}
  </ol>
{% endmacro %}
