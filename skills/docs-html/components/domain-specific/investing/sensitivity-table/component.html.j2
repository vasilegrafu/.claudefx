{# purpose: two-way sensitivity grid: one output across two assumptions, base case marked #}
{# rows: list of (row_head, cells); cells: list of (display, tone, base) — tone low|mid|high #}
{% macro sensitivity_table(cols=[], rows=[], col_label="", row_label="", caption="", note="") %}
  <table class="investing-sens">
  {% if caption %}<caption>{{ caption }}</caption>{% endif %}
    <thead>
      <tr>
        <th class="investing-sens-corner"><span class="investing-sens-row-label">{{ row_label }}</span><span class="investing-sens-col-label">{{ col_label }}</span></th>
        {% for c in cols %}<th>{{ c }}</th>{% endfor %}
      </tr>
    </thead>
    <tbody>
    {% for row_head, cells in rows %}
      <tr>
        <th scope="row">{{ row_head }}</th>
        {% for display, tone, base in cells %}
        <td class="investing-sens-cell{% if tone %} investing-sens-{{ tone }}{% endif %}{% if base %} investing-sens-base{% endif %}">{{ display }}</td>
        {% endfor %}
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% if note %}<p class="investing-sens-note">{{ note }}</p>{% endif %}
{% endmacro %}
