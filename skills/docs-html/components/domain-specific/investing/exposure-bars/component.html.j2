{# purpose: allocation breakdown as labeled percentage bars — sector, geography, asset class #}
{# items: list of (label, percent, value) — percent is a number; value is free text (amount, target, delta) #}
{% macro exposure_bars(items=[], caption="") %}
  <figure class="investing-exposure">
  {% if caption %}<figcaption>{{ caption }}</figcaption>{% endif %}
    {% for label, percent, value in items %}
    <div class="investing-exposure-row">
      <span class="investing-exposure-label">{{ label }}</span>
      <span class="investing-exposure-track"><span class="investing-exposure-fill" data-pct="{{ percent }}%"></span></span>
      <span class="investing-exposure-value">{{ percent }}%{% if value %} <em>{{ value }}</em>{% endif %}</span>
    </div>
    {% endfor %}
  </figure>
{% endmacro %}
