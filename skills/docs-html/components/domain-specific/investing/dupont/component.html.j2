{# purpose: return on equity or capital decomposed into its multiplicative drivers across periods #}
{# factors: list of (name, values); result: (name, values) #}
{% macro dupont(periods=[], factors=[], result=none, caption="", note="") %}
  <table class="investing-fin dupont">
  {% if caption %}<caption>{{ caption }}</caption>{% endif %}
    <thead><tr><th>Driver</th>{% for p in periods %}<th>{{ p }}</th>{% endfor %}</tr></thead>
    <tbody>
    {% for name, values in factors %}
      <tr>
        <th scope="row"><span class="investing-dp-op">{{ "" if loop.first else "×" }}</span>{{ name }}</th>
        {% for v in values %}<td>{{ v }}</td>{% endfor %}
      </tr>
    {% endfor %}
    </tbody>
    {% if result %}
    <tfoot><tr class="investing-total">
      <th scope="row"><span class="investing-dp-op">=</span>{{ result[0] }}</th>
      {% for v in result[1] %}<td>{{ v }}</td>{% endfor %}
    </tr></tfoot>
    {% endif %}
  </table>
  {% if note %}<p class="investing-st-source">{{ note }}</p>{% endif %}
{% endmacro %}
