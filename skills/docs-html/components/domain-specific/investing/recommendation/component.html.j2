{# purpose: the investment call: action, price target, upside, horizon and conviction #}
{# tone: good (accumulate) | neutral (hold) | bad (reduce); facts: list of (label, value) #}
{% macro recommendation(action="", tone="neutral", facts=[], rationale="") %}
  <aside class="investing-reco investing-reco-{{ tone }}">
    <p class="investing-reco-action">{{ action }}</p>
    {% if facts %}
    <dl class="investing-reco-facts">
      {% for label, value in facts %}
      <div><dt>{{ label }}</dt><dd>{{ value }}</dd></div>
      {% endfor %}
    </dl>
    {% endif %}
    {% if rationale %}<p class="investing-reco-rationale">{{ rationale }}</p>{% endif %}
  </aside>
{% endmacro %}
