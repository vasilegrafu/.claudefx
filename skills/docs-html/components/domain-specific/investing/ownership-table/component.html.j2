{# purpose: who owns the company: top holders, stake, and recent change #}
{# rows: list of (holder, type, shares, stake, change, tone) — stake is a number in percent #}
{% macro ownership_table(rows=[], summary=[], caption="", asof="", note="") %}
  {% if summary %}
  <dl class="investing-own-summary">
    {% for label, value in summary %}
    <div><dt>{{ label }}</dt><dd>{{ value }}</dd></div>
    {% endfor %}
  </dl>
  {% endif %}
  <table class="investing-fin ownership">
  {% if caption or asof %}<caption>{{ caption }}{% if asof %} <span class="investing-macro-asof">as of {{ asof }}</span>{% endif %}</caption>{% endif %}
    <thead><tr><th>Holder</th><th>Type</th><th>Shares</th><th class="investing-own-stake-head">Stake</th><th>Change</th></tr></thead>
    <tbody>
    {% for holder, type_, shares, stake, change, tone in rows %}
      <tr>
        <th scope="row">{{ holder }}</th>
        <td class="investing-own-type">{{ type_ }}</td>
        <td>{{ shares }}</td>
        <td class="investing-own-stake">
          <span class="investing-own-track"><span class="investing-own-fill" data-pct="{{ stake }}%"></span></span>
          <span class="investing-own-pct">{{ stake }}%</span>
        </td>
        <td{% if tone %} class="investing-tone-{{ tone }}"{% endif %}>{{ change }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% if note %}<p class="investing-st-source">{{ note }}</p>{% endif %}
{% endmacro %}
