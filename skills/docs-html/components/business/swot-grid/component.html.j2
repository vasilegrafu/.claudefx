{% macro swot_grid(strengths=[], weaknesses=[], opportunities=[], threats=[]) %}
  <div class="swot">
    <div class="strengths"><p>Strengths</p><ul>{% for i in strengths %}<li>{{ i }}</li>{% endfor %}</ul></div>
    <div class="weaknesses"><p>Weaknesses</p><ul>{% for i in weaknesses %}<li>{{ i }}</li>{% endfor %}</ul></div>
    <div class="opportunities"><p>Opportunities</p><ul>{% for i in opportunities %}<li>{{ i }}</li>{% endfor %}</ul></div>
    <div class="threats"><p>Threats</p><ul>{% for i in threats %}<li>{{ i }}</li>{% endfor %}</ul></div>
  </div>
{% endmacro %}
