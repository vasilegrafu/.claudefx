{# purpose: economic indicators with latest, prior, consensus, surprise and direction #}
{# rows: list of (indicator, latest, prior, consensus, surprise, dir) — dir up|down|flat #}
{% macro macro_indicators(rows=[], caption="", asof="") %}
  <table class="fin macro">
  {% if caption or asof %}<caption>{{ caption }}{% if asof %} <span class="macro-asof">as of {{ asof }}</span>{% endif %}</caption>{% endif %}
    <thead><tr><th>Indicator</th><th>Latest</th><th>Prior</th><th>Consensus</th><th>Surprise</th><th class="trend-head">Trend</th></tr></thead>
    <tbody>
    {% for indicator, latest, prior, consensus, surprise, dir in rows %}
      <tr>
        <th scope="row">{{ indicator }}</th>
        <td class="macro-latest">{{ latest }}</td>
        <td>{{ prior }}</td>
        <td>{{ consensus }}</td>
        <td{% if surprise is string and (surprise.startswith("-") or surprise.startswith("−")) %} class="neg"{% endif %}>{{ surprise }}</td>
        <td class="trend trend-{{ dir }}">{{ {"up": "▲", "down": "▼"}.get(dir, "▬") }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
{% endmacro %}
