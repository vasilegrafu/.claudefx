{# purpose: each valuation multiple against peer median and its own history, with the premium #}
{# rows: list of (multiple, current, peers, history, premium, verdict) — verdict cheap|fair|rich #}
{% macro valuation_multiples(rows=[], history_label="5-yr own median", caption="") %}
  <table class="fin multiples">
  {% if caption %}<caption>{{ caption }}</caption>{% endif %}
    <thead><tr><th>Multiple</th><th>Current</th><th>Peer median</th><th>{{ history_label }}</th><th>Premium</th><th>Read</th></tr></thead>
    <tbody>
    {% for multiple, current, peers, history, premium, verdict in rows %}
      <tr>
        <th scope="row">{{ multiple }}</th>
        <td class="mult-current">{{ current }}</td>
        <td>{{ peers }}</td>
        <td>{{ history }}</td>
        <td>{{ premium }}</td>
        <td>{% if verdict %}<span class="badge badge-{{ {"cheap": "good", "fair": "info", "rich": "bad"}.get(verdict, "info") }}">{{ verdict }}</span>{% endif %}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
{% endmacro %}
