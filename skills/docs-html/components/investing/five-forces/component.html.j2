{# purpose: Porter's five forces, each rated from the incumbent's point of view with its evidence #}
{# forces: list of (name, rating, tone, evidence) — tone good|neutral|bad for the incumbent #}
{% macro five_forces(forces=[], caption="", verdict="") %}
  <div class="forces">
  {% if caption %}<p class="forces-caption">{{ caption }}</p>{% endif %}
    <div class="forces-grid">
    {% for name, rating, tone, evidence in forces %}
      <article class="force force-{{ tone }}">
        <p class="force-head">
          <span class="force-name">{{ name }}</span>
          <span class="force-rating">{{ rating }}</span>
        </p>
        <p class="force-evidence">{{ evidence }}</p>
      </article>
    {% endfor %}
    </div>
    {% if verdict %}<p class="forces-verdict">{{ verdict }}</p>{% endif %}
  </div>
{% endmacro %}
