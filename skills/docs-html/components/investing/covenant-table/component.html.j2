{# purpose: financial covenants: the test, the limit, the actual level, and the headroom #}
{# rows: list of (covenant, test, limit, actual, headroom, status) — status pass|tight|breach #}
{% macro covenant_table(rows=[], caption="", asof="", note="") %}
  <table class="fin covenants">
  {% if caption or asof %}<caption>{{ caption }}{% if asof %} <span class="macro-asof">tested at {{ asof }}</span>{% endif %}</caption>{% endif %}
    <thead><tr><th>Covenant</th><th>Test</th><th>Limit</th><th>Actual</th><th>Headroom</th><th>Status</th></tr></thead>
    <tbody>
    {% for covenant, test, limit, actual, headroom, status in rows %}
      <tr class="cov-{{ status }}">
        <th scope="row">{{ covenant }}</th>
        <td class="cov-test">{{ test }}</td>
        <td>{{ limit }}</td>
        <td class="cov-actual">{{ actual }}</td>
        <td>{{ headroom }}</td>
        <td><span class="badge badge-{{ {"pass": "good", "tight": "warn", "breach": "bad"}.get(status, "info") }}">{{ status }}</span></td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% if note %}<p class="st-source">{{ note }}</p>{% endif %}
{% endmacro %}
