{# purpose: cohort retention or vintage performance: cohorts down, periods since start across #}
{# rows: list of (cohort, size, cells) — cells: list of (display, level) with level 0..5 #}
{% macro cohort_table(periods=[], rows=[], caption="", size_label="Size", note="") %}
  <table class="cohorts">
  {% if caption %}<caption>{{ caption }}</caption>{% endif %}
    <thead><tr><th>Cohort</th><th>{{ size_label }}</th>{% for p in periods %}<th>{{ p }}</th>{% endfor %}</tr></thead>
    <tbody>
    {% for cohort, size, cells in rows %}
      <tr>
        <th scope="row">{{ cohort }}</th>
        <td class="cohort-size">{{ size }}</td>
        {% for display, level in cells %}<td class="cohort-cell cohort-l{{ level }}">{{ display }}</td>{% endfor %}
        {% for _ in range(periods | length - cells | length) %}<td class="cohort-empty"></td>{% endfor %}
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% if note %}<p class="st-source">{{ note }}</p>{% endif %}
{% endmacro %}
