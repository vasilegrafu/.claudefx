{# purpose: reported versus consensus for one earnings print, with the surprise #}
{# rows: list of (metric, consensus, actual, surprise, tone) — tone good|bad|neutral #}
{% macro earnings_surprise(rows=[], period="", caption="") %}
  <table class="fin surprise">
  {% if caption or period %}<caption>{{ caption }}{% if period %} <span class="surprise-period">{{ period }}</span>{% endif %}</caption>{% endif %}
    <thead><tr><th>Metric</th><th>Consensus</th><th>Reported</th><th>Surprise</th></tr></thead>
    <tbody>
    {% for metric, consensus, actual, surprise, tone in rows %}
      <tr>
        <th scope="row">{{ metric }}</th>
        <td>{{ consensus }}</td>
        <td class="surprise-actual">{{ actual }}</td>
        <td class="surprise-delta tone-{{ tone }}">{{ surprise }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
{% endmacro %}
