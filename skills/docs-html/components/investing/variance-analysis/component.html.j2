{# purpose: budget versus actual with the variance and whether it is favourable #}
{# rows: list of (line, budget, actual, variance, pct, verdict) — verdict favourable|adverse|neutral #}
{% macro variance_analysis(rows=[], caption="", unit="", period="", total_row=none, note="") %}
  <table class="fin variance">
  {% if caption or period or unit %}<caption>{{ caption }}{% if period %} <span class="macro-asof">{{ period }}</span>{% endif %}{% if unit %} <span class="st-unit">{{ unit }}</span>{% endif %}</caption>{% endif %}
    <thead><tr><th>Line</th><th>Budget</th><th>Actual</th><th>Variance</th><th>%</th><th>Verdict</th></tr></thead>
    <tbody>
    {% for line, budget, actual, variance, pct, verdict in rows %}
      <tr>
        <th scope="row">{{ line }}</th>
        <td>{{ budget }}</td>
        <td class="var-actual">{{ actual }}</td>
        <td{% if variance is string and (variance.startswith("(") or variance.startswith("-") or variance.startswith("−")) %} class="neg"{% endif %}>{{ variance }}</td>
        <td>{{ pct }}</td>
        <td>{% if verdict %}<span class="badge badge-{{ {"favourable": "good", "adverse": "bad"}.get(verdict, "info") }}">{{ verdict }}</span>{% endif %}</td>
      </tr>
    {% endfor %}
    </tbody>
    {% if total_row %}
    <tfoot><tr class="total"><th scope="row">{{ total_row[0] }}</th>{% for v in total_row[1] %}<td>{{ v }}</td>{% endfor %}</tr></tfoot>
    {% endif %}
  </table>
  {% if note %}<p class="st-source">{{ note }}</p>{% endif %}
{% endmacro %}
