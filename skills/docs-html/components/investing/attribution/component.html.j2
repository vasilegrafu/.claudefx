{# purpose: Brinson attribution: allocation effect, selection effect and their total by segment #}
{# rows: list of (segment, pw, bw, pr, br, allocation, selection, total) #}
{% macro attribution(rows=[], caption="", period="", total_row=none, note="") %}
  <table class="fin attribution">
  {% if caption or period %}<caption>{{ caption }}{% if period %} <span class="macro-asof">{{ period }}</span>{% endif %}</caption>{% endif %}
    <thead>
      <tr>
        <th>Segment</th>
        <th>Port. weight</th><th>Bench. weight</th>
        <th>Port. return</th><th>Bench. return</th>
        <th>Allocation</th><th>Selection</th><th>Total</th>
      </tr>
    </thead>
    <tbody>
    {% for segment, pw, bw, pr, br, allocation, selection, total in rows %}
      <tr>
        <th scope="row">{{ segment }}</th>
        <td>{{ pw }}</td><td class="attr-bench">{{ bw }}</td>
        <td>{{ pr }}</td><td class="attr-bench">{{ br }}</td>
        <td{% if allocation is string and (allocation.startswith("-") or allocation.startswith("−")) %} class="neg"{% endif %}>{{ allocation }}</td>
        <td{% if selection is string and (selection.startswith("-") or selection.startswith("−")) %} class="neg"{% endif %}>{{ selection }}</td>
        <td class="attr-total{% if total is string and (total.startswith("-") or total.startswith("−")) %} neg{% endif %}">{{ total }}</td>
      </tr>
    {% endfor %}
    </tbody>
    {% if total_row %}
    <tfoot><tr class="total"><th scope="row">{{ total_row[0] }}</th>{% for v in total_row[1] %}<td>{{ v }}</td>{% endfor %}</tr></tfoot>
    {% endif %}
  </table>
  {% if note %}<p class="st-source">{{ note }}</p>{% endif %}
{% endmacro %}
