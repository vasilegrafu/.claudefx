{# purpose: a formula-based composite score with its inputs, the result, and the band it falls in #}
{# inputs: list of (component, coefficient, value, contribution); bands: list of (label, range, tone) #}
{% macro composite_score(name="", formula="", inputs=[], score="", band="", tone="neutral", bands=[], caption="", note="") %}
  <div class="composite">
    <p class="composite-head">
      <span class="composite-name">{{ name }}</span>
      {% if formula %}<span class="math">{{ formula }}</span>{% endif %}
    </p>
    {% if inputs %}
    <table class="fin composite-inputs">
    {% if caption %}<caption>{{ caption }}</caption>{% endif %}
      <thead><tr><th>Component</th><th>Coefficient</th><th>Value</th><th>Contribution</th></tr></thead>
      <tbody>
      {% for component, coefficient, value, contribution in inputs %}
        <tr>
          <th scope="row">{{ component }}</th>
          <td>{{ coefficient }}</td>
          <td>{{ value }}</td>
          <td{% if contribution is string and (contribution.startswith("(") or contribution.startswith("-") or contribution.startswith("−")) %} class="neg"{% endif %}>{{ contribution }}</td>
        </tr>
      {% endfor %}
      </tbody>
      <tfoot><tr class="total"><th scope="row">Score</th><td></td><td></td><td>{{ score }}</td></tr></tfoot>
    </table>
    {% endif %}
    <p class="composite-band composite-{{ tone }}">
      <span class="composite-band-tag">{{ band }}</span>
      {% if bands %}
      <span class="composite-scale">
        {% for label, range_, btone in bands %}
        <span class="composite-step composite-step-{{ btone }}{% if label == band %} current{% endif %}">{{ label }} <em>{{ range_ }}</em></span>
        {% endfor %}
      </span>
      {% endif %}
    </p>
    {% if note %}<p class="st-source">{{ note }}</p>{% endif %}
  </div>
{% endmacro %}
