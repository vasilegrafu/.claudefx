{# purpose: where the economy or a market sits in a multi-phase cycle #}
{# phases: list of (label, note); at: 0-based index of the current phase #}
{% macro cycle_position(phases=[], at=0, asof="", note="") %}
  <figure class="cycle">
    <ol class="cycle-band">
    {% for label, pnote in phases %}
      <li class="cycle-phase{% if loop.index0 == at %} current{% endif %}"{% if loop.index0 == at %} aria-current="true"{% endif %}>
        <span class="cycle-label">{{ label }}</span>
        {% if pnote %}<span class="cycle-note">{{ pnote }}</span>{% endif %}
      </li>
    {% endfor %}
    </ol>
    {% if note or asof %}
    <figcaption>{{ note }}{% if asof %} <span class="cycle-asof">{{ asof }}</span>{% endif %}</figcaption>
    {% endif %}
  </figure>
{% endmacro %}
