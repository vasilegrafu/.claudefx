{# purpose: the numbered accounting disclosures that statement lines cite, with the ones that matter flagged #}
{# items: list of (num, title, body, flag) — flag "" | watch; each note anchors at id="note-<num>" #}
{% macro footnote_disclosures(items=[], caption="") %}
  <div class="disclosures">
  {% if caption %}<p class="disclosures-caption">{{ caption }}</p>{% endif %}
  {% for num, title, body, flag in items %}
    <section class="disclosure{% if flag %} disclosure-{{ flag }}{% endif %}" id="note-{{ num }}">
      <p class="disclosure-head">
        <span class="disclosure-num">Note {{ num }}</span>
        <span class="disclosure-title">{{ title }}</span>
        {% if flag %}<span class="disclosure-flag">{{ flag }}</span>{% endif %}
      </p>
      <p class="disclosure-body">{{ body }}</p>
    </section>
  {% endfor %}
  </div>
{% endmacro %}
