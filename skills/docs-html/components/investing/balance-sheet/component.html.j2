{# purpose: multi-period balance sheet with an explicit assets = liabilities + equity check #}
{# rows: list of (label, values, kind, note) — kind "" | section | detail | subtotal | total | pct #}
{# note is a disclosure number; it links to the matching id in footnote_disclosures #}
{% macro balance_sheet(periods=[], rows=[], caption="", unit="", source="", check="", balanced=true) %}
  <table class="fin statement st-balance">
  {% if caption or unit %}<caption>{{ caption }}{% if unit %} <span class="st-unit">{{ unit }}</span>{% endif %}</caption>{% endif %}
    <thead><tr><th>{{ "" }}</th>{% for p in periods %}<th>{{ p }}</th>{% endfor %}</tr></thead>
    <tbody>
    {% for label, values, kind, note in rows %}
      <tr class="st-{{ kind if kind else 'line' }}">
        <th scope="row">{{ label }}{% if note %} <a class="st-note" href="#note-{{ note }}">{{ note }}</a>{% endif %}</th>
        {% for v in values %}<td{% if v is string and (v.startswith("(") or v.startswith("-") or v.startswith("−")) %} class="neg"{% endif %}>{{ v }}</td>{% endfor %}
        {% for _ in range(periods | length - values | length) %}<td></td>{% endfor %}
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% if check %}
    <p class="st-check{{ '' if balanced else ' st-check-fail' }}">
      <span class="st-check-tag">{{ "Balances" if balanced else "Does not balance" }}</span> {{ check }}
    </p>
  {% endif %}
  {% if source %}<p class="st-source">{{ source }}</p>{% endif %}
{% endmacro %}
