{# purpose: weighted multi-criteria score with per-criterion rating bar and weighted total #}
{# rows: list of (criterion, weight, score, note) — score out of `scale`; pct computed at compose time #}
{% macro scorecard(rows=[], scale=5, total="", caption="") %}
  <table class="fin scorecard">
  {% if caption %}<caption>{{ caption }}</caption>{% endif %}
    <thead><tr><th>Criterion</th><th>Weight</th><th>Score</th><th>Rating</th><th>Evidence</th></tr></thead>
    <tbody>
    {% for criterion, weight, score, note in rows %}
      <tr>
        <td>{{ criterion }}</td>
        <td>{{ weight }}</td>
        <td>{{ score }} / {{ scale }}</td>
        <td><span class="score-track"><span class="score-fill" data-pct="{{ ((100 * score / scale) if scale else 0) | round(1) }}%"></span></span></td>
        <td>{{ note }}</td>
      </tr>
    {% endfor %}
    </tbody>
    {% if total %}
    <tfoot><tr class="total"><td>Weighted total</td><td></td><td>{{ total }}</td><td></td><td></td></tr></tfoot>
    {% endif %}
  </table>
{% endmacro %}
