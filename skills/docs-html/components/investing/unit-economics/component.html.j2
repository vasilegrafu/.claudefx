{# purpose: customer unit economics: acquisition cost, lifetime value, payback and the ratio #}
{# rows: list of (metric, value, benchmark, note) #}
{% macro unit_economics(rows=[], headline=[], caption="", verdict="", tone="neutral", benchmark_label="Benchmark", note="") %}
  {% if headline %}
  <dl class="unit-headline unit-{{ tone }}">
    {% for label, value in headline %}
    <div><dt>{{ label }}</dt><dd>{{ value }}</dd></div>
    {% endfor %}
  </dl>
  {% endif %}
  <table class="fin uniteco">
  {% if caption %}<caption>{{ caption }}</caption>{% endif %}
    <thead><tr><th>Metric</th><th>Value</th><th>{{ benchmark_label }}</th><th>Reading</th></tr></thead>
    <tbody>
    {% for metric, value, benchmark, reading in rows %}
      <tr>
        <th scope="row">{{ metric }}</th>
        <td class="rm-value">{{ value }}</td>
        <td>{{ benchmark }}</td>
        <td class="rm-note">{{ reading }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% if verdict %}<p class="unit-verdict unit-verdict-{{ tone }}">{{ verdict }}</p>{% endif %}
  {% if note %}<p class="st-source">{{ note }}</p>{% endif %}
{% endmacro %}
