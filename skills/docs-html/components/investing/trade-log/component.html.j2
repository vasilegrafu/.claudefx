{# purpose: dated trades with side, size, price, result and the rationale that justified them #}
{# rows: list of (date, symbol, side, size, price, result, rationale) — side buy|sell #}
{% macro trade_log(rows=[], caption="") %}
  <table class="fin tradelog">
  {% if caption %}<caption>{{ caption }}</caption>{% endif %}
    <thead><tr><th>Date</th><th>Instrument</th><th>Side</th><th>Size</th><th>Price</th><th>Result</th></tr></thead>
    <tbody>
    {% for date, symbol, side, size, price, result, rationale in rows %}
      <tr class="trade">
        <td class="trade-date">{{ date }}</td>
        <th scope="row">{{ symbol }}</th>
        <td><span class="side side-{{ side | lower }}">{{ side }}</span></td>
        <td>{{ size }}</td>
        <td>{{ price }}</td>
        <td{% if result is string and (result.startswith("-") or result.startswith("−")) %} class="neg"{% endif %}>{{ result }}</td>
      </tr>
      {% if rationale %}
      <tr class="trade-note"><td colspan="6">{{ rationale }}</td></tr>
      {% endif %}
    {% endfor %}
    </tbody>
  </table>
{% endmacro %}
