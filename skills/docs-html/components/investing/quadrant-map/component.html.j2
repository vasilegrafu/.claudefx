{# purpose: 2x2 positioning map with items placed by two scores #}
{# items: list of (label, x, y, tone) — x and y are numbers 0..100; positions computed at compose time #}
{% macro quadrant_map(items=[], x_label="", y_label="", quadrants=[], caption="", note="") %}
  <figure class="quadrant">
  {% if caption %}<figcaption>{{ caption }}</figcaption>{% endif %}
    <div class="quadrant-frame">
      <span class="quadrant-y-label">{{ y_label }}</span>
      <div class="quadrant-plot">
        {% for q in quadrants %}<span class="quadrant-zone quadrant-z{{ loop.index }}">{{ q }}</span>{% endfor %}
        {% for label, x, y, tone in items %}
        <span class="quadrant-item{% if tone %} quadrant-{{ tone }}{% endif %}" data-x="{{ x }}%" data-y="{{ y }}%">
          <span class="quadrant-dot"></span><span class="quadrant-label">{{ label }}</span>
        </span>
        {% endfor %}
      </div>
      <span class="quadrant-x-label">{{ x_label }}</span>
    </div>
    {% if note %}<p class="quadrant-note">{{ note }}</p>{% endif %}
  </figure>
{% endmacro %}
