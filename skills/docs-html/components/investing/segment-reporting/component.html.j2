{# purpose: revenue and profit by segment, with each segment's share of both and its margin #}
{# rows: list of (segment, revenue, rev_share, profit, profit_share, margin, growth) — shares are numbers in percent #}
{% macro segment_reporting(rows=[], caption="", unit="", revenue_label="Revenue", profit_label="Profit", total_row=none, source="") %}
  <table class="fin segments">
  {% if caption or unit %}<caption>{{ caption }}{% if unit %} <span class="st-unit">{{ unit }}</span>{% endif %}</caption>{% endif %}
    <thead><tr>
      <th>Segment</th>
      <th>{{ revenue_label }}</th><th class="seg-share-head">% of {{ revenue_label | lower }}</th>
      <th>{{ profit_label }}</th><th class="seg-share-head">% of {{ profit_label | lower }}</th>
      <th>Margin</th><th>y/y</th>
    </tr></thead>
    <tbody>
    {% for segment, revenue, rev_share, profit, profit_share, margin, growth in rows %}
      <tr>
        <th scope="row">{{ segment }}</th>
        <td>{{ revenue }}</td>
        <td class="seg-share">
          <span class="seg-track"><span class="seg-fill" data-pct="{{ rev_share }}%"></span></span>
          <span class="seg-pct">{{ rev_share }}%</span>
        </td>
        <td>{{ profit }}</td>
        <td class="seg-share">
          <span class="seg-track"><span class="seg-fill seg-fill-profit" data-pct="{{ profit_share }}%"></span></span>
          <span class="seg-pct">{{ profit_share }}%</span>
        </td>
        <td>{{ margin }}</td>
        <td{% if growth is string and (growth.startswith("-") or growth.startswith("−")) %} class="neg"{% endif %}>{{ growth }}</td>
      </tr>
    {% endfor %}
    </tbody>
    {% if total_row %}
    <tfoot><tr class="total">
      <th scope="row">{{ total_row[0] }}</th>
      {% for v in total_row[1] %}<td>{{ v }}</td>{% endfor %}
    </tr></tfoot>
    {% endif %}
  </table>
  {% if source %}<p class="st-source">{{ source }}</p>{% endif %}
{% endmacro %}
