{# purpose: where operating cash went — capex, M&A, dividends, buybacks, debt — as a share of it #}
{# rows: list of (use, values, cumulative, share) — share is a number in percent of cumulative operating cash #}
{% macro capital_allocation(periods=[], rows=[], caption="", unit="", source_line=none, note="") %}
  <table class="fin capalloc">
  {% if caption or unit %}<caption>{{ caption }}{% if unit %} <span class="st-unit">{{ unit }}</span>{% endif %}</caption>{% endif %}
    <thead><tr><th>Use of cash</th>{% for p in periods %}<th>{{ p }}</th>{% endfor %}<th>Cumulative</th><th class="ca-share-head">% of source</th></tr></thead>
    {% if source_line %}
    <tbody class="ca-source">
      <tr><th scope="row">{{ source_line[0] }}</th>
        {% for v in source_line[1] %}<td>{{ v }}</td>{% endfor %}
        <td>{{ source_line[2] }}</td><td></td>
      </tr>
    </tbody>
    {% endif %}
    <tbody>
    {% for use, values, cumulative, share in rows %}
      <tr>
        <th scope="row">{{ use }}</th>
        {% for v in values %}<td{% if v is string and (v.startswith("(") or v.startswith("-") or v.startswith("−")) %} class="neg"{% endif %}>{{ v }}</td>{% endfor %}
        <td class="ca-cum">{{ cumulative }}</td>
        <td class="ca-share">
          <span class="ca-track"><span class="ca-fill" data-pct="{{ share }}%"></span></span>
          <span class="ca-pct">{{ share }}%</span>
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% if note %}<p class="st-source">{{ note }}</p>{% endif %}
{% endmacro %}
