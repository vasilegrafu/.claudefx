{# purpose: valuation ranges by method with the current price marked — the football field #}
{# rows: list of (method, low, high, label); offsets computed at compose time, carried as data- attributes #}
{% macro valuation_range(rows=[], scale_min=0, scale_max=100, price=none, price_label="", caption="", unit="") %}
  {% set span = (scale_max - scale_min) if (scale_max - scale_min) else 1 %}
  <figure class="valrange">
  {% if caption %}<figcaption>{{ caption }}</figcaption>{% endif %}
    <div class="valrange-rows">
    {% for method, low, high, label in rows %}
      <div class="valrange-row">
        <span class="valrange-method">{{ method }}</span>
        <span class="valrange-track">
          <span class="valrange-bar" data-lo="{{ (100 * (low - scale_min) / span) | round(2) }}%" data-span="{{ (100 * (high - low) / span) | round(2) }}%"></span>
          {% if price is not none %}<span class="valrange-mark" data-at="{{ (100 * (price - scale_min) / span) | round(2) }}%"></span>{% endif %}
        </span>
        <span class="valrange-value">{{ label }}</span>
      </div>
    {% endfor %}
    </div>
    <p class="valrange-axis"><span>{{ unit }}{{ scale_min }}</span>{% if price is not none %}<span class="valrange-price">{{ price_label }}</span>{% endif %}<span>{{ unit }}{{ scale_max }}</span></p>
  </figure>
{% endmacro %}
