{# purpose: returns across periods for the portfolio, its benchmark and the excess #}
{# rows: list of (label, values, kind) — kind "" | benchmark | excess; negatives auto-tinted #}
{% macro performance_table(periods=[], rows=[], caption="") %}
  <table class="fin perf">
  {% if caption %}<caption>{{ caption }}</caption>{% endif %}
    <thead><tr><th>Series</th>{% for p in periods %}<th>{{ p }}</th>{% endfor %}</tr></thead>
    <tbody>
    {% for label, values, kind in rows %}
      <tr{% if kind %} class="{{ kind }}"{% endif %}>
        <th scope="row">{{ label }}</th>
        {% for v in values %}<td{% if v is string and (v.startswith("-") or v.startswith("−")) %} class="neg"{% endif %}>{{ v }}</td>{% endfor %}
      </tr>
    {% endfor %}
    </tbody>
  </table>
{% endmacro %}
