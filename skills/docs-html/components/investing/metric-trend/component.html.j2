{# purpose: one metric per row across reporting periods, with CAGR and direction #}
{# rows: list of (metric, values, cagr, dir) — dir up|down|flat; values aligns with `periods` #}
{% macro metric_trend(periods=[], rows=[], caption="") %}
  <table class="fin metric-trend">
  {% if caption %}<caption>{{ caption }}</caption>{% endif %}
    <thead><tr><th>Metric</th>{% for p in periods %}<th>{{ p }}</th>{% endfor %}<th>CAGR</th><th class="trend-head">Trend</th></tr></thead>
    <tbody>
    {% for metric, values, cagr, dir in rows %}
      <tr>
        <th scope="row">{{ metric }}</th>
        {% for v in values %}<td>{{ v }}</td>{% endfor %}
        <td class="metric-cagr">{{ cagr }}</td>
        <td class="trend trend-{{ dir }}">{{ {"up": "▲", "down": "▼"}.get(dir, "▬") }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
{% endmacro %}
