{# purpose: receivables or payables split into ageing buckets, with the overdue share #}
{# rows: list of (counterparty, values, total, overdue_share, tone) — overdue_share is a number in percent #}
{% macro aging_schedule(buckets=[], rows=[], caption="", unit="", total_row=none, note="") %}
  <table class="fin aging">
  {% if caption or unit %}<caption>{{ caption }}{% if unit %} <span class="st-unit">{{ unit }}</span>{% endif %}</caption>{% endif %}
    <thead><tr><th>Counterparty</th>{% for b in buckets %}<th>{{ b }}</th>{% endfor %}<th>Total</th><th class="aging-share-head">Overdue</th></tr></thead>
    <tbody>
    {% for counterparty, values, total, overdue_share, tone in rows %}
      <tr>
        <th scope="row">{{ counterparty }}</th>
        {% for v in values %}<td>{{ v }}</td>{% endfor %}
        {% for _ in range(buckets | length - values | length) %}<td></td>{% endfor %}
        <td class="aging-total">{{ total }}</td>
        <td class="aging-share">
          <span class="aging-track"><span class="aging-fill{% if tone %} aging-fill-{{ tone }}{% endif %}" data-pct="{{ overdue_share }}%"></span></span>
          <span class="aging-pct">{{ overdue_share }}%</span>
        </td>
      </tr>
    {% endfor %}
    </tbody>
    {% if total_row %}
    <tfoot><tr class="total"><th scope="row">{{ total_row[0] }}</th>{% for v in total_row[1] %}<td>{{ v }}</td>{% endfor %}</tr></tfoot>
    {% endif %}
  </table>
  {% if note %}<p class="st-source">{{ note }}</p>{% endif %}
{% endmacro %}
