{# type-name: Failure Analysis #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("event", "The failure"),
      ("evidence", "Evidence"),
      ("analysis", "Analysis"),
      ("cause", "Root cause"),
      ("actions", "Corrective actions"),
  ]) }}
  {% call c.section("event", "The failure") %}
    {{ c.facts([
        ("Item", "{{what failed}}"),
        ("When / where", "{{date, location, operating state}}"),
        ("Mode", "{{how it failed — fracture, leak, drift, stoppage}}"),
        ("Impact", "{{consequence — downtime, damage, safety}}"),
    ]) }}
  {% endcall %}
  {% call c.section("evidence", "Evidence") %}
    {% call c.prose() %}{% raw %}{{observations, measurements, photos referenced, operating data around the event}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("analysis", "Analysis") %}
    {% call c.prose() %}{% raw %}{{hypotheses considered and how each was confirmed or excluded by the evidence}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("cause", "Root cause") %}
    {% call c.callout("decision") %}{% call c.prose() %}{% raw %}{{the root cause — and the contributing factors, distinguished from it}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}
  {% call c.section("actions", "Corrective actions") %}
    {{ c.checklist([("pending", "{{action preventing recurrence — owner, deadline}}")]) }}
  {% endcall %}
{% endblock %}
