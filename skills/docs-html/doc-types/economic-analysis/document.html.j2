{# type-name: Economic Analysis #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("summary", "Summary"),
      ("indicators", "Indicators"),
      ("analysis", "Analysis"),
      ("scenarios", "Scenarios"),
      ("implications", "Implications"),
  ]) }}
  {% call c.section("summary", "Summary") %}
    {% call c.lead() %}{% raw %}{{the economy/sector, the assessment, the horizon}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("indicators", "Indicators") %}
    {{ c.financial_table(caption="Key indicators",
        headers=["Indicator", "Latest", "Prior", "Trend"],
        rows=[("", ["{{GDP / CPI / rate / ...}}", "{{v}}", "{{v}}", "{{↑/↓/→}}"])]) }}
  {% endcall %}
  {% call c.section("analysis", "Analysis") %}
    {% call c.prose() %}{% raw %}{{what drives the numbers: demand, supply, policy, external factors}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("scenarios", "Scenarios") %}
    {{ c.scenarios([
        ("{{scenario}}", "good", ["{{assumption}}"], "{{outcome / probability}}"),
        ("{{scenario}}", "neutral", ["{{assumption}}"], "{{outcome / probability}}"),
        ("{{scenario}}", "bad", ["{{assumption}}"], "{{outcome / probability}}"),
    ]) }}
  {% endcall %}
  {% call c.section("implications", "Implications") %}
    {{ c.bullets(["{{consequence for the decision this analysis serves}}"]) }}
  {% endcall %}
{% endblock %}
