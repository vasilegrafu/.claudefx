{# type-name: Industry Analysis #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("summary", "Summary"),
      ("structure", "Market structure"),
      ("forces", "Competitive forces"),
      ("dynamics", "Dynamics &amp; outlook"),
      ("implications", "Implications"),
  ]) }}
  {% call c.section("summary", "Summary") %}
    {% call c.lead() %}{% raw %}{{the industry, its size and growth, the one structural fact that matters most}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("structure", "Market structure") %}
    {{ c.financial_table(caption="Key players",
        headers=["Player", "Share", "Revenue", "Position"],
        rows=[("", ["{{company}}", "{{x%}}", "{{v}}", "{{leader / challenger / niche}}"])]) }}
  {% endcall %}
  {% call c.section("forces", "Competitive forces") %}
    {{ c.facts([
        ("New entrants", "{{barriers — high/low, why}}"),
        ("Suppliers", "{{power — concentration, switching costs}}"),
        ("Buyers", "{{power}}"),
        ("Substitutes", "{{threat}}"),
        ("Rivalry", "{{intensity, on what dimension}}"),
    ]) }}
  {% endcall %}
  {% call c.section("dynamics", "Dynamics &amp; outlook") %}
    {% call c.prose() %}{% raw %}{{what is changing — technology, regulation, demand — and who it favors}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("implications", "Implications") %}
    {{ c.bullets(["{{consequence for the decision this analysis serves — investment, entry, positioning}}"]) }}
  {% endcall %}
{% endblock %}
