{# type-name: Policy Brief #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("summary", "Summary"),
      ("issue", "The issue"),
      ("options", "Options"),
      ("recommendation", "Recommendation"),
  ]) }}
  {% call c.section("summary", "Summary") %}
    {% call c.lead() %}{% raw %}{{the issue, the recommendation, the expected effect — readable by a busy decision maker in 30 seconds}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("issue", "The issue") %}
    {% call c.prose() %}{% raw %}{{the problem with numbers: who is affected, how much, trending which way}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("options", "Options") %}
    {{ c.table(["Option", "Expected effect", "Cost", "Risks"],
        [["{{do nothing}}", "{{effect}}", "{{cost}}", "{{risk}}"],
         ["{{option A}}", "{{effect}}", "{{cost}}", "{{risk}}"]]) }}
  {% endcall %}
  {% call c.section("recommendation", "Recommendation") %}
    {% call c.callout("decision") %}{% call c.prose() %}{% raw %}{{the recommended option, why it beats the others, and how success would be measured}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}
{% endblock %}
