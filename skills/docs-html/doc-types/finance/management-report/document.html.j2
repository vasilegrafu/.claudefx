{# type-name: Management Report #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("highlights", "Highlights"),
      ("results", "Results vs plan"),
      ("commentary", "Commentary"),
      ("actions", "Actions"),
  ]) }}
  {% call c.section("highlights", "Highlights") %}
    {{ c.kpi_tiles([
        ("{{v}}", "{{kpi}}", "up", "{{vs plan}}"),
        ("{{v}}", "{{kpi}}", "down", "{{vs plan}}"),
        ("{{v}}", "{{kpi}}", "flat", "{{vs plan}}"),
    ]) }}
  {% endcall %}
  {% call c.section("results", "Results vs plan") %}
    {{ c.financial_table(caption="{{period}} ({{currency}})",
        headers=["", "Actual", "Plan", "Variance", "Prior"],
        rows=[
          ("", ["{{line}}", "{{v}}", "{{v}}", "{{±v}}", "{{v}}"]),
          ("total", ["Result", "{{v}}", "{{v}}", "{{±v}}", "{{v}}"]),
        ]) }}
  {% endcall %}
  {% call c.section("commentary", "Commentary") %}
    {% call c.prose() %}{% raw %}{{the story behind the variances — causes, one paragraph per material item}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("actions", "Actions") %}
    {{ c.checklist([("pending", "{{corrective action — owner, deadline}}")]) }}
  {% endcall %}
{% endblock %}
