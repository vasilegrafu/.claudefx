{# type-name: Budget #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("summary", "Summary"),
      ("budget", "Budget by category"),
      ("assumptions", "Assumptions"),
      ("tracking", "Tracking"),
  ]) }}
  {% call c.section("summary", "Summary") %}
    {{ c.kpi_tiles([
        ("{{total}}", "Planned spend", "flat", "{{period}}"),
        ("{{total}}", "Planned income", "flat", "{{period}}"),
        ("{{net}}", "Planned net", "up", "{{savings rate}}"),
    ]) }}
  {% endcall %}
  {% call c.section("budget", "Budget by category") %}
    {{ c.financial_table(caption="{{period}} budget ({{currency}})",
        headers=["Category", "Planned", "Actual", "Variance"],
        rows=[
          ("", ["{{category}}", "{{v}}", "{{v}}", "{{±v}}"]),
          ("total", ["Total", "{{v}}", "{{v}}", "{{±v}}"]),
        ]) }}
  {% endcall %}
  {% call c.section("assumptions", "Assumptions") %}
    {{ c.bullets(["{{rate / price / event the numbers depend on}}"]) }}
  {% endcall %}
  {% call c.section("tracking", "Tracking") %}
    {% call c.prose() %}{% raw %}{{how and when actuals get filled in; variance threshold that triggers action}}{% endraw %}{% endcall %}
  {% endcall %}
{% endblock %}
