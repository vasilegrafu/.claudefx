{# type-name: Net Worth Statement #}
{# purpose: assets minus liabilities at a point in time #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("summary", "Summary"),
      ("assets", "Assets"),
      ("liabilities", "Liabilities"),
      ("trend", "Trend"),
  ]) }}
  {% call c.section("summary", "Summary") %}
    {{ c.kpi_tiles([
        ("{{v}}", "Net worth", "up", "{{±vs prior}}"),
        ("{{v}}", "Liquid assets", "flat", "{{months of expenses}}"),
        ("{{x%}}", "Debt / assets", "down", "{{trend}}"),
    ]) }}
  {% endcall %}
  {% call c.section("assets", "Assets") %}
    {{ c.financial_table(caption="As at {{date}} ({{currency}})",
        headers=["Asset", "Value", "Prior", "Notes"],
        rows=[
          ("", ["{{cash / broker / property / pension}}", "{{v}}", "{{v}}", "{{valuation basis}}"]),
          ("total", ["Total assets", "{{v}}", "{{v}}", ""]),
        ]) }}
  {% endcall %}
  {% call c.section("liabilities", "Liabilities") %}
    {{ c.financial_table(headers=["Liability", "Balance", "Rate", "Notes"],
        rows=[
          ("", ["{{loan / mortgage / card}}", "{{v}}", "{{x%}}", "{{term}}"]),
          ("total", ["Total liabilities", "{{v}}", "", ""]),
        ]) }}
  {% endcall %}
  {% call c.section("trend", "Trend") %}
    {% call c.mermaid() %}{% raw %}xychart-beta
  title "Net worth over time"
  x-axis [{{periods}}]
  y-axis "{{currency}}"
  line [{{values}}]{% endraw %}{% endcall %}
  {% endcall %}
{% endblock %}
