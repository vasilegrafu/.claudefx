{# type-name: Cash Flow Forecast #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("summary", "Summary"),
      ("forecast", "Forecast"),
      ("assumptions", "Assumptions"),
      ("stress", "Stress view"),
  ]) }}
  {% call c.section("summary", "Summary") %}
    {% call c.lead() %}{% raw %}{{the horizon, the expected cash trajectory, the tightest point}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("forecast", "Forecast") %}
    {{ c.financial_table(caption="{{scope}} — {{horizon}} ({{currency}})",
        headers=["", "{{p1}}", "{{p2}}", "{{p3}}"],
        rows=[
          ("", ["Opening cash", "{{v}}", "{{v}}", "{{v}}"]),
          ("", ["Inflows", "{{v}}", "{{v}}", "{{v}}"]),
          ("", ["Outflows", "{{(v)}}", "{{(v)}}", "{{(v)}}"]),
          ("total", ["Closing cash", "{{v}}", "{{v}}", "{{v}}"]),
        ]) }}
    {% call c.diagram_mermaid() %}{% raw %}xychart-beta
  title "Closing cash by period"
  x-axis [{{periods}}]
  y-axis "{{currency}}"
  bar [{{values}}]{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("assumptions", "Assumptions") %}
    {{ c.bullets(["{{timing / amount assumption each figure depends on}}"]) }}
  {% endcall %}
  {% call c.section("stress", "Stress view") %}
    {% call c.callout("risk") %}{% call c.prose() %}{% raw %}{{the forecast with the worst plausible timing: does cash go negative, when, and what is the buffer plan}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}
{% endblock %}
