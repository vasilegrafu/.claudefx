{# type-name: Valuation Report #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("summary", "Summary"),
      ("methods", "Methods"),
      ("inputs", "Inputs"),
      ("results", "Results"),
      ("sensitivity", "Sensitivity"),
  ]) }}
  {% call c.section("summary", "Summary") %}
    {% call c.lead() %}{% raw %}{{the asset, the valuation range, the method(s), the date}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("methods", "Methods") %}
    {% call c.prose() %}{% raw %}{{which methods (DCF, multiples, asset-based) and why they fit this asset}}{% endraw %}{% endcall %}
    {% call c.formula() %}{% raw %}V_0 = \sum_{t=1}^{n} \frac{FCF_t}{(1+r)^t} + \frac{TV_n}{(1+r)^n}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("inputs", "Inputs") %}
    {{ c.table(["Input", "Value", "Basis"],
        [["{{growth / discount rate / margin / multiple}}", "{{v}}", "{{where it comes from}}"]]) }}
  {% endcall %}
  {% call c.section("results", "Results") %}
    {{ c.financial_table(headers=["Method", "Low", "Base", "High"],
        rows=[
          ("", ["{{DCF}}", "{{v}}", "{{v}}", "{{v}}"]),
          ("", ["{{Multiples}}", "{{v}}", "{{v}}", "{{v}}"]),
          ("total", ["Concluded range", "{{v}}", "{{v}}", "{{v}}"]),
        ]) }}
  {% endcall %}
  {% call c.section("sensitivity", "Sensitivity") %}
    {{ c.table(["", "{{r low}}", "{{r base}}", "{{r high}}"],
        [["{{g low}}", "{{v}}", "{{v}}", "{{v}}"],
         ["{{g base}}", "{{v}}", "{{v}}", "{{v}}"],
         ["{{g high}}", "{{v}}", "{{v}}", "{{v}}"]]) }}
    {% call c.prose() %}{% raw %}{{which input moves the value most — that is where the diligence belongs}}{% endraw %}{% endcall %}
  {% endcall %}
{% endblock %}
