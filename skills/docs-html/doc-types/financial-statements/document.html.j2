{# type-name: Financial Statements #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("income", "Income statement"),
      ("balance", "Balance sheet"),
      ("cashflow", "Cash flow"),
      ("notes", "Notes"),
  ]) }}
  {% call c.section("income", "Income statement") %}
    {{ c.financial_table(caption="{{entity}} — {{period}} ({{currency}})",
        headers=["", "{{period}}", "{{prior}}"],
        rows=[
          ("", ["Revenue", "{{v}}", "{{v}}"]),
          ("", ["Expenses", "{{(v)}}", "{{(v)}}"]),
          ("total", ["Net result", "{{v}}", "{{v}}"]),
        ]) }}
  {% endcall %}
  {% call c.section("balance", "Balance sheet") %}
    {{ c.financial_table(caption="As at {{date}} ({{currency}})",
        headers=["", "{{date}}", "{{prior}}"],
        rows=[
          ("", ["Assets", "{{v}}", "{{v}}"]),
          ("subtotal", ["Total assets", "{{v}}", "{{v}}"]),
          ("", ["Liabilities", "{{v}}", "{{v}}"]),
          ("subtotal", ["Total liabilities", "{{v}}", "{{v}}"]),
          ("total", ["Equity", "{{v}}", "{{v}}"]),
        ]) }}
  {% endcall %}
  {% call c.section("cashflow", "Cash flow") %}
    {{ c.financial_table(headers=["", "{{period}}"],
        rows=[
          ("", ["Operating", "{{v}}"]),
          ("", ["Investing", "{{v}}"]),
          ("", ["Financing", "{{v}}"]),
          ("total", ["Net change in cash", "{{v}}"]),
        ]) }}
  {% endcall %}
  {% call c.section("notes", "Notes") %}
    {% call c.prose() %}{% raw %}{{basis of preparation, unusual items, anything a reader would ask about}}{% endraw %}{% endcall %}
  {% endcall %}
{% endblock %}
