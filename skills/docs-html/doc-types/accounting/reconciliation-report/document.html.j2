{# type-name: Reconciliation Report #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("scope", "Scope"),
      ("reconciliation", "Reconciliation"),
      ("differences", "Differences"),
      ("conclusion", "Conclusion"),
  ]) }}
  {% call c.section("scope", "Scope") %}
    {{ c.facts([
        ("Accounts", "{{internal records vs bank / broker statement}}"),
        ("As at", "{{date}}"),
        ("Prepared by", "{{who}}"),
    ]) }}
  {% endcall %}
  {% call c.section("reconciliation", "Reconciliation") %}
    {{ c.financial_table(caption="({{currency}})",
        headers=["", "Amount"],
        rows=[
          ("", ["Balance per {{statement}}", "{{v}}"]),
          ("", ["+ {{items in records, not yet on statement}}", "{{v}}"]),
          ("", ["− {{items on statement, not yet in records}}", "{{(v)}}"]),
          ("subtotal", ["Adjusted statement balance", "{{v}}"]),
          ("total", ["Balance per records", "{{v}}"]),
        ]) }}
  {% endcall %}
  {% call c.section("differences", "Differences") %}
    {{ c.table(["Item", "Amount", "Cause", "Resolution"],
        [["{{difference}}", "{{v}}", "{{timing / error / fee}}", "{{action, owner}}"]]) }}
  {% endcall %}
  {% call c.section("conclusion", "Conclusion") %}
    {% call c.callout("decision") %}{% call c.prose() %}{% raw %}{{reconciled fully / with open items — a c.badge() verdict and the follow-up}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}
{% endblock %}
