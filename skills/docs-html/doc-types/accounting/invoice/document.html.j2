{# type-name: Invoice #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {% call c.section("invoice", "Invoice {{number}}") %}
    {{ c.facts([
        ("From", "{{issuer — name, address, tax id}}"),
        ("To", "{{client — name, address, tax id}}"),
        ("Invoice no.", "{{number}}"),
        ("Issue date", "{{date}}"),
        ("Due date", "{{date}}"),
    ]) }}
    {{ c.financial_table(caption="Items ({{currency}})",
        headers=["Description", "Qty", "Unit price", "Amount"],
        rows=[
          ("", ["{{service / item}}", "{{n}}", "{{v}}", "{{v}}"]),
          ("subtotal", ["Subtotal", "", "", "{{v}}"]),
          ("", ["{{VAT x%}}", "", "", "{{v}}"]),
          ("total", ["Total due", "", "", "{{v}}"]),
        ]) }}
    {{ c.facts([
        ("Payment", "{{IBAN / method}}"),
        ("Reference", "{{payment reference}}"),
        ("Terms", "{{late terms, if any}}"),
    ]) }}
  {% endcall %}
{% endblock %}
