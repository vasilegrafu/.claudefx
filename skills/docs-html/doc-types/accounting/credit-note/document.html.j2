{# type-name: Credit Note #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {% call c.section("credit-note", "Credit note {{number}}") %}
    {{ c.party_block(from_title="Issuer", from_lines=["{{name}}", "{{address}}", "{{tax id}}"],
                     to_title="Client", to_lines=["{{name}}", "{{address}}", "{{tax id}}"]) }}
    {{ c.facts([
        ("Credit note no.", "{{number}}"),
        ("Date", "{{date}}"),
        ("Corrects invoice", "{{invoice number}}"),
        ("Reason", "{{return / error / discount}}"),
    ]) }}
    {{ c.financial_table(caption="Credited items ({{currency}})",
        headers=["Description", "Qty", "Unit price", "Amount"],
        rows=[
          ("", ["{{item}}", "{{n}}", "{{v}}", '<span class="neg">({{v}})</span>']),
          ("subtotal", ["Subtotal", "", "", '<span class="neg">({{v}})</span>']),
          ("", ["{{VAT x%}}", "", "", '<span class="neg">({{v}})</span>']),
          ("total", ["Total credited", "", "", '<span class="neg">({{v}})</span>']),
        ]) }}
    {% call c.prose() %}{% raw %}{{settlement: refund method or applied against which balance}}{% endraw %}{% endcall %}
  {% endcall %}
{% endblock %}
