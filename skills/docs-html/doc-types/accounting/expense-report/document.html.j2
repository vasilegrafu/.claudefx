{# type-name: Expense Report #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {% call c.section("claim", "Expense claim") %}
    {{ c.facts([
        ("Claimant", "{{name}}"),
        ("Period / trip", "{{scope}}"),
        ("Cost center", "{{code / project}}"),
    ]) }}
    {{ c.financial_table(caption="Expenses ({{currency}})",
        headers=["Date", "Description", "Category", "Amount"],
        rows=[
          ("", ["{{date}}", "{{what}}", "{{category}}", "{{v}}"]),
          ("total", ["", "", "Total claimed", "{{v}}"]),
        ]) }}
    {% call c.prose() %}{% raw %}{{receipts attached / linked; anything unusual explained}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("approval", "Approval") %}
    {{ c.approval_block([
        ("{{claimant}}", "Claimant"),
        ("", "Approver"),
    ]) }}
  {% endcall %}
{% endblock %}
