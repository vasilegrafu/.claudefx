{# type-name: Standard Operating Procedure #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("purpose", "Purpose &amp; scope"),
      ("prerequisites", "Prerequisites"),
      ("procedure", "Procedure"),
      ("exceptions", "Exceptions &amp; escalation"),
  ]) }}
  {% call c.section("purpose", "Purpose &amp; scope") %}
    {{ c.facts([
        ("Task", "{{what this procedure accomplishes}}"),
        ("Who", "{{roles allowed / expected to perform it}}"),
        ("When", "{{trigger or schedule}}"),
    ]) }}
  {% endcall %}
  {% call c.section("prerequisites", "Prerequisites") %}
    {{ c.checklist([("pending", "{{access / tool / condition required before starting}}")]) }}
  {% endcall %}
  {% call c.section("procedure", "Procedure") %}
    {{ c.steps([
        "{{step — one action, its expected result stated}}",
        "{{step}}",
    ]) }}
  {% endcall %}
  {% call c.section("exceptions", "Exceptions &amp; escalation") %}
    {% call c.prose() %}{% raw %}{{what can go wrong at which step, what to do, who to call when off-script}}{% endraw %}{% endcall %}
  {% endcall %}
{% endblock %}
