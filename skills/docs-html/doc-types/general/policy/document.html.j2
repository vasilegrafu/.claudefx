{# type-name: Policy #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("purpose", "Purpose &amp; scope"),
      ("rules", "Policy"),
      ("exceptions", "Exceptions"),
      ("review", "Review"),
  ]) }}
  {% call c.section("purpose", "Purpose &amp; scope") %}
    {% call c.prose() %}{% raw %}{{what this policy protects or enables; who and what it applies to}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("rules", "Policy") %}
    {{ c.requirement(id="POL-001", title="{{rule}}", priority="must", label="Must",
        description="{{the rule, verifiable by a third party}}",
        fit="{{how compliance is checked}}") }}
  {% endcall %}
  {% call c.section("exceptions", "Exceptions") %}
    {% call c.prose() %}{% raw %}{{who may grant an exception, how it is recorded, how long it lasts}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("review", "Review") %}
    {{ c.facts([("Owner", "{{who maintains this policy}}"), ("Review cadence", "{{when it is revisited}}")]) }}
  {% endcall %}
{% endblock %}
