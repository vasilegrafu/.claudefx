{# type-name: Statement of Work #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("parties", "Parties"),
      ("objectives", "Objectives"),
      ("scope", "Scope of work"),
      ("deliverables", "Deliverables &amp; acceptance"),
      ("schedule", "Schedule"),
      ("pricing", "Pricing"),
      ("assumptions", "Assumptions &amp; exclusions"),
      ("approval", "Approval"),
  ]) }}

  {% call c.section("parties", "Parties") %}
    {{ c.facts([("{{key}}", "{{value}}")]) }}
  {% endcall %}

  {% call c.section("objectives", "Objectives") %}
    {% call c.prose() %}{% raw %}{{...}}{% endraw %}{% endcall %}
  {% endcall %}

  {% call c.section("scope", "Scope of work") %}
    {% call c.prose() %}{% raw %}{{...}}{% endraw %}{% endcall %}
  {% endcall %}

  {% call c.section("deliverables", "Deliverables &amp; acceptance") %}
    {{ c.table(["{{col1}}", "{{col2}}"], [["{{...}}", "{{...}}"]]) }}
  {% endcall %}

  {% call c.section("schedule", "Schedule") %}
    {{ c.timeline([("done", "{{when}}", "{{title}}", "{{...}}")]) }}
  {% endcall %}

  {% call c.section("pricing", "Pricing") %}
    {{ c.table(["{{col1}}", "{{col2}}"], [["{{...}}", "{{...}}"]]) }}
  {% endcall %}

  {% call c.section("assumptions", "Assumptions &amp; exclusions") %}
    {{ c.bullets(["{{...}}"]) }}
  {% endcall %}

  {% call c.section("approval", "Approval") %}
    {{ c.approval_block([("{{name}}", "{{role}}")]) }}
  {% endcall %}

{% endblock %}
