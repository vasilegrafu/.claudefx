{# type-name: Proposal #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("parties", "Parties"),
      ("understanding", "Understanding of the need"),
      ("offer", "The offer"),
      ("price", "Price &amp; terms"),
      ("acceptance", "Validity &amp; acceptance"),
  ]) }}
  {% call c.section("parties", "Parties") %}
    {{ c.party_block(from_title="Provider", from_lines=["{{name}}", "{{address}}", "{{contact}}"],
                     to_title="Client", to_lines=["{{name}}", "{{address}}", "{{contact}}"]) }}
  {% endcall %}
  {% call c.section("understanding", "Understanding of the need") %}
    {% call c.prose() %}{% raw %}{{the client's problem in the client's terms — proof you listened}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("offer", "The offer") %}
    {{ c.bullets(["{{deliverable — concrete, verifiable}}"]) }}
    {% call c.prose() %}{% raw %}{{approach and timeline; what is explicitly OUT of scope}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("price", "Price &amp; terms") %}
    {{ c.financial_table(headers=["Item", "Amount"],
        rows=[("", ["{{deliverable / phase}}", "{{v}}"]),
              ("total", ["Total ({{currency}}, {{excl/incl}} VAT)", "{{v}}"])]) }}
    {{ c.facts([("Payment", "{{schedule}}"), ("Assumptions", "{{what the price depends on}}")]) }}
  {% endcall %}
  {% call c.section("acceptance", "Validity &amp; acceptance") %}
    {% call c.prose() %}{% raw %}{{valid until date; how acceptance happens}}{% endraw %}{% endcall %}
    {{ c.approval_block([("{{provider}}", "Provider"), ("", "Client")]) }}
  {% endcall %}
{% endblock %}
