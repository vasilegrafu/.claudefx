{# type-name: Roadmap #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("goals", "Goals"),
      ("timeline", "Timeline"),
      ("progress", "Progress"),
      ("risks", "Risks &amp; dependencies"),
  ]) }}
  {% call c.section("goals", "Goals") %}
    {% call c.lead() %}{% raw %}{{where this is going and why, in one paragraph}}{% endraw %}{% endcall %}
    {{ c.bullets(["{{goal — outcome-phrased, with a measurable done-condition}}"]) }}
  {% endcall %}
  {% call c.section("timeline", "Timeline") %}
    {{ c.timeline([
        ("done", "{{period}}", "{{milestone}}", "{{what shipped}}"),
        ("current", "{{period}}", "{{milestone}}", "{{what is in flight}}"),
        ("", "{{period}}", "{{milestone}}", "{{what is planned}}"),
    ]) }}
  {% endcall %}
  {% call c.section("progress", "Progress") %}
    {{ c.meter(label="{{goal}}", value=0, max=100, display="{{0%}}") }}
  {% endcall %}
  {% call c.section("risks", "Risks &amp; dependencies") %}
    {{ c.bullets(["{{what could move the dates, and on whom/what it depends}}"]) }}
  {% endcall %}
{% endblock %}
