{# type-name: Decision Record #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("context", "Context"),
      ("options", "Options considered"),
      ("decision", "Decision"),
      ("consequences", "Consequences"),
  ]) }}
  {% call c.section("context", "Context") %}
    {% call c.prose() %}{% raw %}{{the situation forcing a decision; constraints; who is affected}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("options", "Options considered") %}
    {{ c.pros_cons(pros=["{{option A strengths}}"], cons=["{{option A weaknesses}}"]) }}
    {% call c.prose() %}{% raw %}{{each serious option in a paragraph — including the one not chosen}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("decision", "Decision") %}
    {% call c.callout("decision") %}{% call c.prose() %}{% raw %}{{the decision, stated in one sentence, and its main justification}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}
  {% call c.section("consequences", "Consequences") %}
    {{ c.bullets(["{{what becomes easier / harder / irreversible because of this}}"]) }}
  {% endcall %}
{% endblock %}
