{# type-name: Threat Model #}
{# purpose: assets, threats and mitigations for a system (STRIDE-style) #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("scope", "Scope &amp; assets"),
      ("architecture", "Trust boundaries"),
      ("threats", "Threats"),
      ("matrix", "Risk view"),
      ("mitigations", "Mitigations"),
  ]) }}
  {% call c.section("scope", "Scope &amp; assets") %}
    {% call c.prose() %}{% raw %}{{the system under analysis; the assets worth attacking (data, money, access)}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("architecture", "Trust boundaries") %}
    {% call c.mermaid() %}{% raw %}flowchart LR
  user([User]) --> app[App]
  app --> db[(Data)]{% endraw %}{% endcall %}
    {% call c.prose() %}{% raw %}{{where trust changes: network edges, auth boundaries, third parties}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("threats", "Threats") %}
    {{ c.table(["ID", "Threat", "STRIDE", "Prob", "Impact"],
        [["THR-01", "{{who does what to which asset}}", "{{S/T/R/I/D/E}}", "{{1-5}}", "{{1-5}}"]]) }}
  {% endcall %}
  {% call c.section("matrix", "Risk view") %}
    {{ c.risk_matrix([("THR-01", 3, 4, "{{threat summary}}")]) }}
  {% endcall %}
  {% call c.section("mitigations", "Mitigations") %}
    {{ c.checklist([("pending", "THR-01: {{control — owner, verification}}")]) }}
  {% endcall %}
{% endblock %}
