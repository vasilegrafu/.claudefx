{# type-name: Disaster Recovery Plan #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("objectives", "Objectives"),
      ("scenarios", "Disaster scenarios"),
      ("recovery", "Recovery procedures"),
      ("testing", "Testing"),
  ]) }}
  {% call c.section("objectives", "Objectives") %}
    {{ c.facts([
        ("RTO", "{{max acceptable downtime}}"),
        ("RPO", "{{max acceptable data loss}}"),
        ("Scope", "{{systems covered}}"),
        ("Backups", "{{what, where, cadence, retention}}"),
    ]) }}
  {% endcall %}
  {% call c.section("scenarios", "Disaster scenarios") %}
    {{ c.table(["Scenario", "Likelihood", "Impact", "Procedure"],
        [["{{disk loss / machine loss / site loss / corruption}}", "{{l}}", "{{i}}", "{{link to procedure below}}"]]) }}
  {% endcall %}
  {% call c.section("recovery", "Recovery procedures") %}
    {% call c.subsection("recovery-1", "{{scenario}}") %}
      {{ c.steps(["{{step, with expected duration and verification}}"]) }}
    {% endcall %}
  {% endcall %}
  {% call c.section("testing", "Testing") %}
    {% call c.prose() %}{% raw %}{{restore-test cadence; date and result of the last real restore test}}{% endraw %}{% endcall %}
  {% endcall %}
{% endblock %}
