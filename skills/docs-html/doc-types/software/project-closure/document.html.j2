{# type-name: Project Closure #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("outcome", "Outcome vs objectives"),
      ("deliverables", "Deliverables &amp; handover"),
      ("lessons", "Lessons learned"),
      ("loose-ends", "Loose ends"),
      ("signoff", "Sign-off"),
  ]) }}
  {% call c.section("outcome", "Outcome vs objectives") %}
    {{ c.table(["Objective", "Result", "Verdict"],
        [["{{what was promised}}", "{{what happened}}", "{{a c.badge() Met/Partial/Missed}}"]]) }}
  {% endcall %}
  {% call c.section("deliverables", "Deliverables &amp; handover") %}
    {{ c.table(["Deliverable", "Location", "Owner going forward"],
        [["{{artifact}}", "{{repo / path / url}}", "{{who maintains it now}}"]]) }}
  {% endcall %}
  {% call c.section("lessons", "Lessons learned") %}
    {{ c.bullets(["{{what to repeat / avoid next time — specific, actionable}}"]) }}
  {% endcall %}
  {% call c.section("loose-ends", "Loose ends") %}
    {{ c.checklist([("pending", "{{open item — new owner, deadline}}")]) }}
  {% endcall %}
  {% call c.section("signoff", "Sign-off") %}
    {{ c.approval_block([("{{lead}}", "Project lead"), ("", "Sponsor")]) }}
  {% endcall %}
{% endblock %}
