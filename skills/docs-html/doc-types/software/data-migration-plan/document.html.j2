{# type-name: Data Migration Plan #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("scope", "Scope"),
      ("mapping", "Mapping"),
      ("procedure", "Procedure"),
      ("validation", "Validation"),
      ("rollback", "Rollback"),
  ]) }}
  {% call c.section("scope", "Scope") %}
    {{ c.facts([
        ("Source", "{{system / schema / volume}}"),
        ("Target", "{{system / schema}}"),
        ("Window", "{{when, allowed downtime}}"),
        ("Owner", "{{who runs it}}"),
    ]) }}
  {% endcall %}
  {% call c.section("mapping", "Mapping") %}
    {{ c.table(["Source", "Target", "Transformation", "Notes"],
        [["{{table.field}}", "{{table.field}}", "{{rule / cast / default}}", "{{edge cases}}"]]) }}
  {% endcall %}
  {% call c.section("procedure", "Procedure") %}
    {{ c.steps(["{{step with expected result and duration estimate}}"]) }}
  {% endcall %}
  {% call c.section("validation", "Validation") %}
    {{ c.checklist([("pending", "{{count / checksum / spot-check that proves completeness}}")]) }}
  {% endcall %}
  {% call c.section("rollback", "Rollback") %}
    {% call c.callout("warning") %}{% call c.prose() %}{% raw %}{{the point of no return, and the exact way back before it}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}
{% endblock %}
