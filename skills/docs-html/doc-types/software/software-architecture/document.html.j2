{# type-name: Software Architecture #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("overview", "Overview"),
      ("system-context", "System Context"),
      ("containers", "Containers"),
      ("components", "Components"),
      ("data", "Data"),
      ("deployment", "Deployment"),
      ("decisions", "Key Decisions"),
      ("risks", "Risks &amp; Technical Debt"),
  ]) }}

  {% call c.section("overview", "Overview") %}
    {% call c.prose() %}{% raw %}{{...}}{% endraw %}{% endcall %}
  {% endcall %}

  {% call c.section("system-context", "System Context") %}
    {% call c.diagram_mermaid() %}{% raw %}flowchart LR
  user([{{User}}]) --> sys[{{System}}]
  sys --> ext[({{External system}})]{% endraw %}{% endcall %}
    {% call c.prose() %}{% raw %}{{...}}{% endraw %}{% endcall %}
  {% endcall %}

  {% call c.section("containers", "Containers") %}
    {% call c.diagram_mermaid() %}{% raw %}flowchart TD
  {{...}}{% endraw %}{% endcall %}
    {{ c.table(["{{col1}}", "{{col2}}"], [["{{...}}", "{{...}}"]]) }}
  {% endcall %}

  {% call c.section("components", "Components") %}
    {% call c.prose() %}{% raw %}{{...}}{% endraw %}{% endcall %}
  {% endcall %}

  {% call c.section("data", "Data") %}
    {% call c.prose() %}{% raw %}{{...}}{% endraw %}{% endcall %}
  {% endcall %}

  {% call c.section("deployment", "Deployment") %}
    {{ c.facts([("{{key}}", "{{value}}")]) }}
  {% endcall %}

  {% call c.section("decisions", "Key Decisions") %}
    {{ c.table(["{{col1}}", "{{col2}}"], [["{{...}}", "{{...}}"]]) }}
  {% endcall %}

  {% call c.section("risks", "Risks &amp; Technical Debt") %}
    {% call c.callout(type="risk") %}{% call c.prose() %}{% raw %}{{...}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}

{% endblock %}
