{# type-name: Performance Test Report #}
{# purpose: load/performance test results vs targets #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("setup", "Setup"),
      ("results", "Results"),
      ("analysis", "Analysis"),
      ("verdict", "Verdict"),
  ]) }}
  {% call c.section("setup", "Setup") %}
    {{ c.facts([
        ("System under test", "{{version, config, hardware}}"),
        ("Workload", "{{scenario, rates, duration}}"),
        ("Targets", "{{the SLO numbers being tested against}}"),
        ("Tooling", "{{generator, measurement method}}"),
    ]) }}
  {% endcall %}
  {% call c.section("results", "Results") %}
    {{ c.table(["Metric", "Target", "Measured", "Verdict"],
        [["{{p95 latency / throughput / error rate}}", "{{t}}", "{{m}}", "{{a c.badge() Pass/Fail}}"]]) }}
    {% call c.mermaid() %}{% raw %}xychart-beta
  title "{{latency over load}}"
  x-axis [{{load points}}]
  y-axis "{{ms}}"
  line [{{values}}]{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("analysis", "Analysis") %}
    {% call c.prose() %}{% raw %}{{where it saturates, the bottleneck evidence, anomalies explained}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("verdict", "Verdict") %}
    {% call c.callout("decision") %}{% call c.prose() %}{% raw %}{{fit for the target load or not; conditions and follow-ups}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}
{% endblock %}
