{# type-name: Technical Specification #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("summary", "Summary"),
      ("background", "Background"),
      ("approach", "Proposed approach"),
      ("design", "Detailed design"),
      ("alternatives", "Alternatives"),
      ("rollout", "Rollout"),
      ("testing", "Testing"),
  ]) }}

  {% call c.section("summary", "Summary") %}
    {% call c.lead() %}{% raw %}{{what changes and why, in 1-2 sentences}}{% endraw %}{% endcall %}
  {% endcall %}

  {% call c.section("background", "Background") %}
    {% call c.prose() %}{% raw %}{{...}}{% endraw %}{% endcall %}
  {% endcall %}

  {% call c.section("approach", "Proposed approach") %}
    {% call c.diagram_mermaid() %}{% raw %}flowchart LR
  {{...}}{% endraw %}{% endcall %}
  {% endcall %}

  {% call c.section("design", "Detailed design") %}
    {% call c.code_block(path="{{path}}", lang="{{lang}}") %}{% raw %}{{...}}{% endraw %}{% endcall %}
  {% endcall %}

  {% call c.section("alternatives", "Alternatives") %}
    {{ c.table(["{{col1}}", "{{col2}}"], [["{{...}}", "{{...}}"]]) }}
  {% endcall %}

  {% call c.section("rollout", "Rollout") %}
    {{ c.steps(["{{step}}"]) }}
  {% endcall %}

  {% call c.section("testing", "Testing") %}
    {{ c.checklist([("pending", "{{item}}")]) }}
  {% endcall %}

{% endblock %}
