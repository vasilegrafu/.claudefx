{# type-name: Data Analysis Report #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("summary", "Summary"),
      ("data", "Data"),
      ("method", "Methodology"),
      ("results", "Results"),
      ("caveats", "Caveats"),
  ]) }}
  {% call c.section("summary", "Summary") %}
    {% call c.lead() %}{% raw %}{{what was analyzed, headline result, the one caveat that matters}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("data", "Data") %}
    {{ c.facts([
        ("Source", "{{where the data comes from}}"),
        ("Period", "{{coverage}}"),
        ("Size", "{{rows / assets / observations}}"),
        ("Cleaning", "{{exclusions, adjustments}}"),
    ]) }}
  {% endcall %}
  {% call c.section("method", "Methodology") %}
    {% call c.prose() %}{% raw %}{{transformations, statistics/models used, why they fit the question}}{% endraw %}{% endcall %}
    {% call c.code(lang="python") %}{% raw %}{{the key computation, if code carries the method better than prose}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("results", "Results") %}
    {% call c.diagram_mermaid() %}{% raw %}xychart-beta
  title "{{headline chart}}"
  x-axis [{{...}}]
  y-axis "{{unit}}"
  bar [{{...}}]{% endraw %}{% endcall %}
    {{ c.table(["Metric", "Value", "Interpretation"],
        [["{{metric}}", "{{v}}", "{{meaning}}"]]) }}
  {% endcall %}
  {% call c.section("caveats", "Caveats") %}
    {{ c.bullets(["{{bias / gap / assumption that limits the conclusion}}"]) }}
  {% endcall %}
{% endblock %}
