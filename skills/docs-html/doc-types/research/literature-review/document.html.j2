{# type-name: Literature Review #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("scope", "Scope &amp; question"),
      ("sources", "Sources compared"),
      ("themes", "Themes"),
      ("gaps", "Gaps &amp; open questions"),
      ("references", "References"),
  ]) }}
  {% call c.section("scope", "Scope &amp; question") %}
    {% call c.prose() %}{% raw %}{{the question the literature is read against; inclusion criteria for sources}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("sources", "Sources compared") %}
    {{ c.table(["Source", "Approach", "Key claim", "Quality"],
        [["{{author, year}}", "{{method}}", "{{claim}}", "{{strong / weak, why}}"]]) }}
  {% endcall %}
  {% call c.section("themes", "Themes") %}
    {% call c.prose() %}{% raw %}{{where the sources agree, where they conflict, and why the conflicts exist}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("gaps", "Gaps &amp; open questions") %}
    {{ c.bullets(["{{what nobody has answered — the openings for new work}}"]) }}
  {% endcall %}
  {% call c.section("references", "References") %}
    {{ c.references([("ref-1", "{{full citation}}")]) }}
  {% endcall %}
{% endblock %}
