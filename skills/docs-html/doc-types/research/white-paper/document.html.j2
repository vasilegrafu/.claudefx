{# type-name: White Paper #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("summary", "Executive summary"),
      ("problem", "The problem"),
      ("approach", "The approach"),
      ("evidence", "Evidence"),
      ("implications", "Implications"),
      ("references", "References"),
  ]) }}
  {% call c.section("summary", "Executive summary") %}
    {% call c.lead() %}{% raw %}{{the position in one paragraph — what you argue and why the reader should care}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("problem", "The problem") %}
    {% call c.prose() %}{% raw %}{{the state of things and why it is inadequate — concrete costs, not vibes}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("approach", "The approach") %}
    {% call c.prose() %}{% raw %}{{the proposed idea / method / position, explained to an intelligent outsider}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("evidence", "Evidence") %}
    {% call c.prose() %}{% raw %}{{data, cases, or argument supporting the position; address the strongest objection}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("implications", "Implications") %}
    {{ c.bullets(["{{what should change if the argument is accepted}}"]) }}
  {% endcall %}
  {% call c.section("references", "References") %}
    {{ c.references([("ref-1", "{{source}}")]) }}
  {% endcall %}
{% endblock %}
