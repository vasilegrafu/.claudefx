{# type-name: Research Report #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("summary", "Executive summary"),
      ("question", "Question &amp; background"),
      ("method", "Method"),
      ("findings", "Findings"),
      ("conclusion", "Conclusion &amp; limitations"),
      ("references", "References"),
  ]) }}
  {% call c.section("summary", "Executive summary") %}
    {% call c.lead() %}{% raw %}{{question, method in one clause, the main finding, the caveat}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("question", "Question &amp; background") %}
    {% call c.prose() %}{% raw %}{{the precise question; why it matters; what was already known}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("method", "Method") %}
    {% call c.prose() %}{% raw %}{{data/sources, approach, tools — enough for someone to reproduce it}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("findings", "Findings") %}
    {% call c.prose() %}{% raw %}{{finding by finding: claim, evidence, strength}}{% endraw %}{% endcall %}
    {{ c.table(["Finding", "Evidence", "Confidence"],
        [["{{claim}}", "{{data / source}}", "{{high / medium / low}}"]]) }}
  {% endcall %}
  {% call c.section("conclusion", "Conclusion &amp; limitations") %}
    {% call c.prose() %}{% raw %}{{answer to the question; what this does NOT establish; next questions}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("references", "References") %}
    {{ c.references([("ref-1", "{{source}}")]) }}
  {% endcall %}
{% endblock %}
