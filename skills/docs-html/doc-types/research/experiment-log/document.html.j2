{# type-name: Experiment Log #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("question", "Line of inquiry"),
      ("experiments", "Experiments"),
      ("findings", "Running conclusions"),
  ]) }}
  {% call c.section("question", "Line of inquiry") %}
    {% call c.lead() %}{% raw %}{{what this series of experiments is trying to establish}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("experiments", "Experiments") %}
    {% call c.subsection("exp-001", "EXP-001 — {{date}} — {{short title}}") %}
      {{ c.facts([
          ("Hypothesis", "{{what you expected and why}}"),
          ("Setup", "{{data / parameters / code version}}"),
          ("Result", "{{what happened — numbers}}"),
          ("Verdict", "{{a c.badge() Supported/Refuted/Inconclusive}}"),
      ]) }}
      {% call c.prose() %}{% raw %}{{interpretation; what the next experiment should change}}{% endraw %}{% endcall %}
    {% endcall %}
  {% endcall %}
  {% call c.section("findings", "Running conclusions") %}
    {{ c.bullets(["{{what the series has established so far, with the experiments that support it}}"]) }}
  {% endcall %}
{% endblock %}
