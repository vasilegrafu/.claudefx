{# type-name: Bill of Materials #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("scope", "Scope"),
      ("bom", "Bill of materials"),
      ("notes", "Notes"),
  ]) }}
  {% call c.section("scope", "Scope") %}
    {{ c.facts([
        ("Assembly", "{{what this BOM builds}}"),
        ("Revision", "{{drawing / design revision it matches}}"),
    ]) }}
  {% endcall %}
  {% call c.section("bom", "Bill of materials") %}
    {{ c.table(["#", "Part", "Spec / part no.", "Qty", "Unit", "Source"],
        [["1", "{{part name}}", "{{standard / manufacturer ref}}", "{{n}}", "{{pcs/m/kg}}", "{{supplier / stock}}"]]) }}
  {% endcall %}
  {% call c.section("notes", "Notes") %}
    {{ c.bullets(["{{substitution rules, critical items, long-lead warnings}}"]) }}
  {% endcall %}
{% endblock %}
