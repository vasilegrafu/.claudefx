{# type-name: Risk Assessment #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("scope", "Scope &amp; method"),
      ("register", "Risk register"),
      ("matrix", "Risk matrix"),
      ("controls", "Controls"),
  ]) }}
  {% call c.section("scope", "Scope &amp; method") %}
    {{ c.facts([
        ("Subject", "{{system / process / site assessed}}"),
        ("Method", "{{FMEA / HAZOP / what-if — and the scales used}}"),
        ("Team", "{{who assessed, when}}"),
    ]) }}
  {% endcall %}
  {% call c.section("register", "Risk register") %}
    {{ c.table(["ID", "Failure / hazard", "Cause", "Effect", "P", "I", "Score"],
        [["RSK-01", "{{what goes wrong}}", "{{why}}", "{{consequence}}", "{{1-5}}", "{{1-5}}", "{{P×I}}"]]) }}
  {% endcall %}
  {% call c.section("matrix", "Risk matrix") %}
    {{ c.risk_matrix([("RSK-01", 3, 4, "{{failure summary}}")]) }}
  {% endcall %}
  {% call c.section("controls", "Controls") %}
    {{ c.checklist([("pending", "RSK-01: {{prevention or mitigation — owner, deadline, residual score}}")]) }}
  {% endcall %}
{% endblock %}
