{# type-name: Design Calculation Note #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("given", "Given"),
      ("assumptions", "Assumptions"),
      ("method", "Method"),
      ("calculation", "Calculation"),
      ("result", "Result &amp; check"),
  ]) }}
  {% call c.section("given", "Given") %}
    {{ c.facts([
        ("Objective", "{{what is being sized / verified}}"),
        ("Inputs", "{{loads, dimensions, material properties — with units}}"),
        ("Standard", "{{code / norm applied}}"),
    ]) }}
  {% endcall %}
  {% call c.section("assumptions", "Assumptions") %}
    {{ c.bullets(["{{simplification and its justification}}"]) }}
  {% endcall %}
  {% call c.section("method", "Method") %}
    {% call c.prose() %}{% raw %}{{governing relations and why they apply; reference the standard's clauses}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("calculation", "Calculation") %}
    {% call c.code() %}{% raw %}{{the calculation, step by step — plain text or code, every value with units}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("result", "Result &amp; check") %}
    {{ c.facts([
        ("Result", "{{value ± tolerance, units}}"),
        ("Utilization", "{{demand / capacity}}"),
        ("Verdict", "{{a c.badge() Pass/Fail}}"),
    ]) }}
    {% call c.prose() %}{% raw %}{{sanity check by an independent route (order of magnitude, limiting case)}}{% endraw %}{% endcall %}
  {% endcall %}
{% endblock %}
