{# type-name: Maintenance Plan #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("scope", "Scope"),
      ("schedule", "Schedule"),
      ("tasks", "Task definitions"),
      ("records", "Records"),
  ]) }}
  {% call c.section("scope", "Scope") %}
    {{ c.facts([
        ("Equipment", "{{what is maintained}}"),
        ("Strategy", "{{preventive / condition-based / run-to-failure, per item}}"),
        ("Owner", "{{who executes / who verifies}}"),
    ]) }}
  {% endcall %}
  {% call c.section("schedule", "Schedule") %}
    {{ c.table(["Item", "Task", "Interval", "Last done", "Next due"],
        [["{{equipment}}", "{{task}}", "{{interval / condition}}", "{{date}}", "{{date}}"]]) }}
  {% endcall %}
  {% call c.section("tasks", "Task definitions") %}
    {% call c.subsection("task-1", "{{task}}") %}
      {{ c.steps(["{{step, with acceptance criterion (torque, clearance, reading)}}"]) }}
    {% endcall %}
  {% endcall %}
  {% call c.section("records", "Records") %}
    {% call c.prose() %}{% raw %}{{where completion is recorded; what triggers escalation (finding worse than X)}}{% endraw %}{% endcall %}
  {% endcall %}
{% endblock %}
