{# type-name: Equipment Specification #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("purpose", "Purpose &amp; scope"),
      ("requirements", "Requirements"),
      ("conditions", "Operating conditions"),
      ("acceptance", "Acceptance"),
  ]) }}
  {% call c.section("purpose", "Purpose &amp; scope") %}
    {% call c.prose() %}{% raw %}{{what the equipment must do, where it operates, what this spec covers}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("requirements", "Requirements") %}
    {{ c.requirement(id="EQ-001", title="{{performance requirement}}",
        priority="must", label="Must",
        description="{{parameter, value, tolerance, units}}",
        fit="{{how it will be verified — test, inspection, certificate}}") }}
  {% endcall %}
  {% call c.section("conditions", "Operating conditions") %}
    {{ c.facts([
        ("Environment", "{{temperature, humidity, atmosphere}}"),
        ("Duty", "{{cycle, load profile, lifetime}}"),
        ("Interfaces", "{{power, mounting, controls}}"),
    ]) }}
  {% endcall %}
  {% call c.section("acceptance", "Acceptance") %}
    {{ c.acceptance_criteria(id="AC-001", title="{{acceptance scenario}}",
        given=["{{installed condition}}"],
        when=["{{test performed}}"],
        then=["{{measured outcome within spec}}"]) }}
  {% endcall %}
{% endblock %}
