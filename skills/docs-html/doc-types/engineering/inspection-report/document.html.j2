{# type-name: Inspection Report #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("scope", "Scope"),
      ("findings", "Findings"),
      ("disposition", "Disposition"),
  ]) }}
  {% call c.section("scope", "Scope") %}
    {{ c.facts([
        ("Subject", "{{item / installation inspected}}"),
        ("Reference", "{{spec / drawing / standard inspected against}}"),
        ("Date &amp; inspector", "{{who, when}}"),
        ("Method", "{{visual / dimensional / NDT / functional}}"),
    ]) }}
  {% endcall %}
  {% call c.section("findings", "Findings") %}
    {{ c.table(["#", "Item checked", "Requirement", "Observed", "Verdict"],
        [["1", "{{feature}}", "{{required value}}", "{{measured}}", "{{a c.badge() Pass/Fail}}"]]) }}
    {% call c.prose() %}{% raw %}{{narrative for any nonconformance: evidence, photos referenced, severity}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("disposition", "Disposition") %}
    {% call c.callout("decision") %}{% call c.prose() %}{% raw %}{{accept / rework / reject / concession — who decided, follow-up actions}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}
{% endblock %}
