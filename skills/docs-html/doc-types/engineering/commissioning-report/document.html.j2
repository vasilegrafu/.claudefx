{# type-name: Commissioning Report #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("scope", "Scope"),
      ("tests", "Commissioning tests"),
      ("deviations", "Deviations"),
      ("handover", "Handover"),
  ]) }}
  {% call c.section("scope", "Scope") %}
    {{ c.facts([
        ("Installation", "{{what was commissioned}}"),
        ("Against", "{{specification / design reference}}"),
        ("When / who", "{{dates, commissioning party, witnesses}}"),
    ]) }}
  {% endcall %}
  {% call c.section("tests", "Commissioning tests") %}
    {{ c.table(["#", "Test", "Required", "Measured", "Verdict"],
        [["1", "{{functional / performance test}}", "{{spec value}}", "{{measured}}", "{{a c.badge() Pass/Fail}}"]]) }}
  {% endcall %}
  {% call c.section("deviations", "Deviations") %}
    {{ c.table(["Item", "Deviation", "Disposition"],
        [["{{item}}", "{{how it differs from spec}}", "{{accepted / rectify by date / rejected}}"]]) }}
  {% endcall %}
  {% call c.section("handover", "Handover") %}
    {% call c.prose() %}{% raw %}{{what was handed over (documentation, spares, training); open punch-list items}}{% endraw %}{% endcall %}
    {{ c.approval_block([("{{commissioner}}", "Commissioning"), ("", "Client / operator")]) }}
  {% endcall %}
{% endblock %}
