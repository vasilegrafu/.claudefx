{# type-name: Portfolio Review #}
{# purpose: periodic review of holdings and performance #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("summary", "Summary"),
      ("performance", "Performance"),
      ("allocation", "Allocation vs targets"),
      ("positions", "Position review"),
      ("actions", "Actions"),
  ]) }}
  {% call c.section("summary", "Summary") %}
    {{ c.kpi_tiles([
        ("{{+x.x%}}", "Period return", "up", "{{vs benchmark}}"),
        ("{{x.x%}}", "Max drawdown", "flat", "{{period}}"),
        ("{{n}}", "Open positions", "flat", "—"),
        ("{{x%}}", "Cash", "flat", "{{target x%}}"),
    ]) }}
    {% call c.prose() %}{% raw %}{{the period in three sentences: what worked, what hurt, what changed}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("performance", "Performance") %}
    {% call c.mermaid() %}{% raw %}xychart-beta
  title "Portfolio vs benchmark (indexed)"
  x-axis [Jan, Feb, Mar, Apr, May, Jun]
  y-axis "Index" 90 --> 120
  line [100, 103, 101, 107, 110, 112]
  line [100, 101, 102, 104, 105, 107]{% endraw %}{% endcall %}
    {% call c.prose() %}{% raw %}{{attribution: which positions/decisions drove the delta}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("allocation", "Allocation vs targets") %}
    {{ c.financial_table(headers=["Bucket", "Target", "Actual", "Drift"],
        rows=[("", ["{{bucket}}", "{{x%}}", "{{y%}}", "{{±z%}}"])]) }}
  {% endcall %}
  {% call c.section("positions", "Position review") %}
    {{ c.table(["Position", "Weight", "Period P/L", "Thesis status"],
        [["{{ticker}}", "{{x%}}", "{{±y%}}", "{{intact / weakening / broken}}"]]) }}
  {% endcall %}
  {% call c.section("actions", "Actions") %}
    {{ c.checklist([("pending", "{{rebalance / trim / add / exit — with size}}")]) }}
  {% endcall %}
{% endblock %}
