{# type-name: Investment Policy Statement #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("purpose", "Purpose &amp; objectives"),
      ("constraints", "Constraints"),
      ("allocation", "Strategic allocation"),
      ("rules", "Rules"),
      ("review", "Review &amp; exceptions"),
  ]) }}
  {% call c.section("purpose", "Purpose &amp; objectives") %}
    {% call c.lead() %}{% raw %}{{whose money, what it is for, return objective and the risk that is acceptable to reach it}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("constraints", "Constraints") %}
    {{ c.facts([
        ("Horizon", "{{time horizon}}"),
        ("Liquidity", "{{cash needs, when}}"),
        ("Tax", "{{jurisdiction / wrapper constraints}}"),
        ("Exclusions", "{{never-invest list}}"),
    ]) }}
  {% endcall %}
  {% call c.section("allocation", "Strategic allocation") %}
    {{ c.financial_table(headers=["Bucket", "Target", "Min", "Max"],
        rows=[("", ["{{asset class}}", "{{x%}}", "{{min%}}", "{{max%}}"])]) }}
  {% endcall %}
  {% call c.section("rules", "Rules") %}
    {{ c.requirement(id="IPS-001", title="{{position sizing rule}}",
        priority="must", label="Must",
        description="{{the rule, stated so a third party could verify compliance}}",
        fit="{{how compliance is checked}}") }}
    {{ c.requirement(id="IPS-002", title="{{drawdown / de-risking rule}}",
        priority="must", label="Must",
        description="{{trigger and mandatory action}}",
        fit="{{how compliance is checked}}") }}
  {% endcall %}
  {% call c.section("review", "Review &amp; exceptions") %}
    {% call c.prose() %}{% raw %}{{review cadence; how an exception is granted and recorded (never retroactively)}}{% endraw %}{% endcall %}
  {% endcall %}
{% endblock %}
