{# type-name: Earnings Note #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("numbers", "The numbers"),
      ("vs-thesis", "Versus the thesis"),
      ("action", "Action"),
  ]) }}
  {% call c.section("numbers", "The numbers") %}
    {{ c.financial_table(caption="{{company}} — {{quarter}}",
        headers=["Metric", "Actual", "Expected", "YoY"],
        rows=[("", ["{{revenue / margin / eps / guidance}}", "{{v}}", "{{v}}", "{{±%}}"])]) }}
    {% call c.prose() %}{% raw %}{{one paragraph: the quarter in substance, not the market reaction}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("vs-thesis", "Versus the thesis") %}
    {{ c.table(["Thesis pillar", "This quarter's evidence", "Status"],
        [["{{claim from the investment-thesis}}", "{{what the quarter showed}}", "{{a c.badge() Intact/Weakening/Broken}}"]]) }}
  {% endcall %}
  {% call c.section("action", "Action") %}
    {% call c.callout("decision") %}{% call c.prose() %}{% raw %}{{hold / add / trim / exit — and whether the thesis document needs a modify}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}
{% endblock %}
