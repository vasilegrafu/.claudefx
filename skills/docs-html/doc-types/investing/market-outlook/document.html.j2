{# type-name: Market Outlook #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("view", "The view"),
      ("indicators", "What the data says"),
      ("scenarios", "Scenarios"),
      ("positioning", "Positioning implications"),
      ("falsifiers", "What would change this view"),
  ]) }}
  {% call c.section("view", "The view") %}
    {% call c.lead() %}{% raw %}{{the stance in one paragraph: regime, direction, conviction level, horizon}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("indicators", "What the data says") %}
    {{ c.table(["Indicator", "Level", "Trend", "Read"],
        [["{{indicator}}", "{{value}}", "{{↑/↓/→}}", "{{what it implies}}"]]) }}
  {% endcall %}
  {% call c.section("scenarios", "Scenarios") %}
    {{ c.scenarios([
        ("{{scenario}}", "good", ["{{assumption}}"], "{{market outcome / probability}}"),
        ("{{scenario}}", "neutral", ["{{assumption}}"], "{{market outcome / probability}}"),
        ("{{scenario}}", "bad", ["{{assumption}}"], "{{market outcome / probability}}"),
    ]) }}
  {% endcall %}
  {% call c.section("positioning", "Positioning implications") %}
    {{ c.bullets(["{{what to hold more / less of, given the scenarios and their odds}}"]) }}
  {% endcall %}
  {% call c.section("falsifiers", "What would change this view") %}
    {{ c.bullets(["{{observable event or data print that kills the thesis}}"]) }}
  {% endcall %}
{% endblock %}
