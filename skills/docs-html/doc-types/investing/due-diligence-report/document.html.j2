{# type-name: Due Diligence Report #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("summary", "Executive summary"),
      ("business", "Business &amp; moat"),
      ("financials", "Financials"),
      ("management", "Management &amp; governance"),
      ("swot", "SWOT"),
      ("assessment", "Assessment"),
      ("references", "References"),
  ]) }}
  {% call c.section("summary", "Executive summary") %}
    {% call c.lead() %}{% raw %}{{the subject, the purpose of the diligence, the verdict in one paragraph}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("business", "Business &amp; moat") %}
    {% call c.prose() %}{% raw %}{{what it sells, to whom, unit economics, competitive advantage and its durability}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("financials", "Financials") %}
    {{ c.financial_table(caption="{{key figures}}",
        headers=["", "{{yr-2}}", "{{yr-1}}", "{{yr}}"],
        rows=[("", ["{{metric}}", "{{v}}", "{{v}}", "{{v}}"])]) }}
    {% call c.prose() %}{% raw %}{{quality of earnings, balance-sheet health, red flags checked}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("management", "Management &amp; governance") %}
    {% call c.prose() %}{% raw %}{{track record, incentives, capital allocation, governance concerns}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("swot", "SWOT") %}
    {{ c.swot_grid(strengths=["{{...}}"], weaknesses=["{{...}}"],
              opportunities=["{{...}}"], threats=["{{...}}"]) }}
  {% endcall %}
  {% call c.section("assessment", "Assessment") %}
    {{ c.pros_cons(pros=["{{...}}"], cons=["{{...}}"]) }}
    {% call c.callout("decision") %}{% call c.prose() %}{% raw %}{{proceed / pass / investigate further — and what would change it}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}
  {% call c.section("references", "References") %}
    {{ c.references([("ref-1", "{{source}}")]) }}
  {% endcall %}
{% endblock %}
