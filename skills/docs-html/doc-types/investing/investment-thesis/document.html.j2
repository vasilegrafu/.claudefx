{# type-name: Investment Thesis #}
{# purpose: argued case for buying/holding an investment #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("summary", "Summary"),
      ("thesis", "Thesis"),
      ("valuation", "Valuation"),
      ("scenarios", "Scenarios"),
      ("catalysts", "Catalysts"),
      ("risks", "Risks &amp; invalidation"),
      ("decision", "Decision"),
  ]) }}
  {% call c.section("summary", "Summary") %}
    {{ c.security_header(ticker="{{TICKER}}", name="{{Company name}}",
        exchange="{{exchange}}", asof="{{as-of date}}",
        facts=[("Price", "{{px}}"), ("Market cap", "{{mcap}}"),
               ("Sector", "{{sector}}"), ("ADV", "{{liquidity}}")]) }}
    {{ c.recommendation(action="{{Buy / Hold / Reduce}}", tone="neutral",
        facts=[("Price target", "{{pt}}"), ("Upside", "{{x%}}"),
               ("Horizon", "{{months}}"), ("Conviction", "{{high/medium/low}}"),
               ("Position size", "{{pct of portfolio}}")],
        rationale="{{one sentence: the bet, in the fewest words that survive scrutiny}}") }}
    {% call c.lead() %}{% raw %}{{one paragraph: the asset, the bet, the expected return, the horizon}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("thesis", "Thesis") %}
    {% call c.prose() %}{% raw %}{{why this is mispriced — the variant view, in 2–4 paragraphs}}{% endraw %}{% endcall %}
    {# Each pillar carries its own falsifier. A thesis whose claims cannot be
       disproved is a preference, not an argument. #}
    {{ c.thesis_pillars([
        ("{{claim the thesis rests on}}",
         "{{the evidence for it}}",
         "{{what observation would break it}}"),
        ("{{second claim}}", "{{evidence}}", "{{falsifier}}"),
        ("{{third claim}}", "{{evidence}}", "{{falsifier}}"),
    ]) }}
  {% endcall %}
  {% call c.section("valuation", "Valuation") %}
    {{ c.valuation_multiples(caption="{{multiples vs peers and own history}}",
        history_label="{{5-yr median}}",
        rows=[("{{P/E}}", "{{subject}}", "{{peer median}}", "{{own history}}",
               "{{premium}}", "fair"),
              ("{{EV/EBITDA}}", "{{subject}}", "{{peer median}}", "{{own history}}",
               "{{premium}}", "fair")]) }}
    {# One scale for every method — a football field whose bars are drawn on
       different scales compares nothing. #}
    {{ c.valuation_range(caption="{{value by method — the football field}}",
        scale_min=0, scale_max=100, price=50, price_label="{{current price}}",
        unit="$",
        rows=[("{{DCF}}", 30, 70, "{{30–70}}"),
              ("{{Multiples}}", 40, 80, "{{40–80}}"),
              ("{{Sum of parts}}", 35, 65, "{{35–65}}")]) }}
    {% call c.prose() %}{% raw %}{{method and key inputs; what the market assumes vs what you assume}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("scenarios", "Scenarios") %}
    {{ c.scenarios([
        ("Bull", "good", ["{{assumption}}"], "{{outcome / target}}"),
        ("Base", "neutral", ["{{assumption}}"], "{{outcome / target}}"),
        ("Bear", "bad", ["{{assumption}}"], "{{outcome / target}}"),
    ]) }}
    {# The scenarios above describe; this one prices them. Probabilities must
       sum to 100% — an expected value built on 130% of probability is not one. #}
    {{ c.expected_value(caption="{{probability-weighted outcome}}",
        total="{{weighted expected return}}",
        rows=[("Bull", "good", "{{p%}}", "{{target}}", "{{return}}", "{{weighted}}"),
              ("Base", "neutral", "{{p%}}", "{{target}}", "{{return}}", "{{weighted}}"),
              ("Bear", "bad", "{{p%}}", "{{target}}", "{{return}}", "{{weighted}}")]) }}
  {% endcall %}
  {% call c.section("catalysts", "Catalysts") %}
    {{ c.catalyst_timeline([
        ("{{date}}", "{{event that closes the gap}}", "up", "{{likelihood}}",
         "{{what it would prove}}"),
        ("{{date}}", "{{event}}", "mixed", "{{likelihood}}", "{{note}}"),
    ]) }}
  {% endcall %}
  {% call c.section("risks", "Risks &amp; invalidation") %}
    {{ c.risk_metrics(caption="{{risk against the benchmark}}",
        benchmark_label="{{benchmark}}",
        rows=[("{{Beta}}", "{{value}}", "{{bench}}", "{{note}}"),
              ("{{Max drawdown}}", "{{value}}", "{{bench}}", "{{note}}")]) }}
    {% call c.callout("risk") %}{% call c.prose() %}{% raw %}{{the strongest argument against; what evidence would make you exit}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}
  {% call c.section("decision", "Decision") %}
    {% call c.callout("decision") %}{% call c.prose() %}{% raw %}{{action, size, entry conditions, review date}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}
{% endblock %}
