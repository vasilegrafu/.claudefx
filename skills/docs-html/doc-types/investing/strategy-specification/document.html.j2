{# type-name: Strategy Specification #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("idea", "Idea &amp; edge"),
      ("universe", "Universe &amp; data"),
      ("rules", "Rules"),
      ("risk", "Risk controls"),
      ("evaluation", "Evaluation criteria"),
  ]) }}
  {% call c.section("idea", "Idea &amp; edge") %}
    {% call c.lead() %}{% raw %}{{the hypothesis: why this edge exists and why it persists}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("universe", "Universe &amp; data") %}
    {{ c.facts([
        ("Universe", "{{instruments, filters}}"),
        ("Data", "{{sources, frequency, history needed}}"),
        ("Rebalance", "{{frequency / trigger}}"),
    ]) }}
  {% endcall %}
  {% call c.section("rules", "Rules") %}
    {{ c.requirement(id="STR-001", title="Entry", priority="must", label="Rule",
        description="{{the entry condition — computable from the data, no judgment}}",
        fit="{{how the backtest verifies it fired correctly}}") }}
    {{ c.requirement(id="STR-002", title="Exit", priority="must", label="Rule",
        description="{{exit / stop condition}}",
        fit="{{verification}}") }}
    {{ c.requirement(id="STR-003", title="Sizing", priority="must", label="Rule",
        description="{{position size formula}}",
        fit="{{verification}}") }}
  {% endcall %}
  {% call c.section("risk", "Risk controls") %}
    {{ c.bullets(["{{max positions / exposure / drawdown kill-switch}}"]) }}
  {% endcall %}
  {% call c.section("evaluation", "Evaluation criteria") %}
    {% call c.prose() %}{% raw %}{{the metrics and thresholds that would make this strategy ACCEPTED — declared before the backtest runs}}{% endraw %}{% endcall %}
  {% endcall %}
{% endblock %}
