{# type-name: Backtest Report #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("setup", "Setup"),
      ("results", "Results"),
      ("equity", "Equity curve"),
      ("robustness", "Robustness"),
      ("verdict", "Verdict"),
  ]) }}
  {% call c.section("setup", "Setup") %}
    {{ c.facts([
        ("Strategy", "{{strategy-specification name + version}}"),
        ("Window", "{{in-sample / out-of-sample periods}}"),
        ("Costs", "{{commission, slippage, spread modeled}}"),
        ("Engine", "{{code / library / atlas module}}"),
    ]) }}
  {% endcall %}
  {% call c.section("results", "Results") %}
    {{ c.financial_table(headers=["Metric", "Strategy", "Benchmark"],
        rows=[
          ("", ["CAGR", "{{x%}}", "{{x%}}"]),
          ("", ["Max drawdown", "{{x%}}", "{{x%}}"]),
          ("", ["Sharpe", "{{v}}", "{{v}}"]),
          ("", ["Trades / turnover", "{{n}}", "—"]),
        ]) }}
  {% endcall %}
  {% call c.section("equity", "Equity curve") %}
    {% call c.diagram_mermaid() %}{% raw %}xychart-beta
  title "Equity curve vs benchmark (indexed)"
  x-axis [{{periods}}]
  y-axis "Index"
  line [{{strategy}}]
  line [{{benchmark}}]{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("robustness", "Robustness") %}
    {{ c.bullets([
        "{{out-of-sample vs in-sample degradation}}",
        "{{parameter sensitivity — does ±20% on each parameter kill it}}",
        "{{costs sensitivity — result at 2× assumed costs}}",
    ]) }}
    {% call c.callout("warning") %}{% call c.prose() %}{% raw %}{{overfitting risks honestly: how many variants were tried before this one}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}
  {% call c.section("verdict", "Verdict") %}
    {% call c.callout("decision") %}{% call c.prose() %}{% raw %}{{accepted / rejected against the spec's pre-declared criteria; next step}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}
{% endblock %}
