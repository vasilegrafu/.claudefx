{# type-name: Financial Profile #}
{# purpose: where a company's money comes from, where it goes, what it owns, and how that shape changed #}
{% extends "doc-types/base.html.j2" %}
{% block content %}
  {{ c.toc([
      ("snapshot", "Snapshot"),
      ("income", "Where the money comes from"),
      ("cash", "Where the money goes"),
      ("position", "What it owns and owes"),
      ("per-share", "Per share"),
      ("evolution", "How it evolved"),
      ("peers", "How it compares"),
      ("reading", "Reading"),
  ]) }}
  {% call c.section("snapshot", "Snapshot") %}
    {{ c.security_header(ticker="{{TICKER}}", name="{{Company name}}",
        exchange="{{exchange}}", asof="{{TTM to <period end>}}",
        facts=[("Price", "{{px}}"), ("Market cap", "{{mcap}}"),
               ("Revenue TTM", "{{rev}}"), ("Net income TTM", "{{ni}}"),
               ("Sector", "{{sector}}")]) }}
    {# BASIS OF PREPARATION. Every figure below is stale by construction — a
       filing describes a period that has already ended. State the REPORT DATE
       so a reader can measure that staleness instead of guessing it, and say
       which exhibit uses which period. Three different dates get conflated
       routinely: when the period ended, when it was filed, and when the price
       was taken. They are not the same date and the gaps between them matter. #}
    {% call c.callout("note") %}
      {{ c.facts([
          ("Report date", "{{today — the reference for every date below}}"),
          ("Latest period", "{{FYxxxx Qx, ended <date>}}"),
          ("Filed", "{{date the latest figures became public}}"),
          ("Price as of", "{{date — a market price is not a filing date}}"),
          ("Currency and unit", "{{USD, $ millions unless stated}}"),
          ("Trailing figures", "{{TTM = sum of the four quarters to <period end>}}"),
          ("Annual exhibits", "{{which exhibits use the last full fiscal year, and why}}"),
          ("Source", "{{filings via <provider>; derived figures marked}}"),
      ]) }}
    {% endcall %}
    {% call c.lead() %}{% raw %}{{one paragraph: what the business sells, to whom, and the one structural fact about its economics a reader should carry into the rest of the document}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("income", "Where the money comes from") %}
    {# CONSERVATION. Inflows must equal outflows at EVERY intermediate node, and
       nothing in the rendering checks it — an unbalanced sankey draws perfectly
       and lies. Check every sum by hand before publishing.
       Roles carry the colour (source/stage/cost/retained) — never colour a node. #}
    {{ c.sankey(
        nodes=[("{{Segment A}}", "source"), ("{{Segment B}}", "source"),
               ("{{Segment C}}", "source"),
               ("Revenue", "stage"), ("Cost of revenue", "cost"),
               ("Gross profit", "stage"), ("R&D", "cost"),
               ("SG&A", "cost"), ("Operating income", "stage"),
               ("Tax", "cost"), ("Net income", "retained")],
        links=[("{{Segment A}}", "Revenue", 50), ("{{Segment B}}", "Revenue", 30),
               ("{{Segment C}}", "Revenue", 20),
               ("Revenue", "Cost of revenue", 55), ("Revenue", "Gross profit", 45),
               ("Gross profit", "R&D", 8), ("Gross profit", "SG&A", 7),
               ("Gross profit", "Operating income", 30),
               ("Operating income", "Tax", 6),
               ("Operating income", "Net income", 24)],
        height=460, unit="{{$ millions}}",
        caption="{{Company}} {{period}} — revenue to net income",
        note="{{one sentence: what the shape says — where the margin is made and what consumes it}}") }}
    {{ c.segment_reporting(caption="{{revenue and profit by segment}}",
        unit="{{$M}}",
        rows=[("{{Segment A}}", "{{rev}}", 50, "{{profit}}", 55, "{{margin}}", "{{growth}}"),
              ("{{Segment B}}", "{{rev}}", 30, "{{profit}}", 30, "{{margin}}", "{{growth}}"),
              ("{{Segment C}}", "{{rev}}", 20, "{{profit}}", 15, "{{margin}}", "{{growth}}")],
        source="{{filing and page}}") }}
    {% call c.prose() %}{% raw %}{{which segment actually pays for the company — revenue share and profit share are rarely the same number, and the gap is the point}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("cash", "Where the money goes") %}
    {# The section above is ACCOUNTING; this one is CASH, and they disagree.
       Buybacks, dividends and debt repayment consume real money and appear
       nowhere on the income statement. Gross up investing rather than netting
       it, so capital expenditure stays a visible node. Sources must equal uses. #}
    {{ c.sankey(
        nodes=[("Operating cash flow", "source"), ("{{Other sources}}", "source"),
               ("Cash available", "stage"),
               ("Capital expenditure", "cost"), ("Buybacks", "cost"),
               ("Dividends", "cost"), ("Debt repayment", "cost"),
               ("Cash retained", "retained")],
        links=[("Operating cash flow", "Cash available", 80),
               ("{{Other sources}}", "Cash available", 20),
               ("Cash available", "Capital expenditure", 15),
               ("Cash available", "Buybacks", 45),
               ("Cash available", "Dividends", 20),
               ("Cash available", "Debt repayment", 12),
               ("Cash available", "Cash retained", 8)],
        height=400, unit="{{$ millions}}",
        caption="{{Company}} {{period}} — cash generated and deployed",
        note="{{one sentence: what management actually did with the money}}") }}
    {% call c.prose() %}{% raw %}{{reinvestment versus return of capital — how much went back into the business against how much went to shareholders}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("position", "What it owns and owes") %}
    {# The picture answers in one look what the table below answers with
       arithmetic: how much of what it owns does the company actually own?
       Assets flow in, claims flow out, equity is the residual.

       A BALANCE SHEET IS A STOCK, NOT A FLOW. Nothing moves along these
       ribbons — the roles encode direction and there is no direction here.
       This diagram shows composition and claim, and the note beneath it should
       say so, or a reader trained by the two sankeys above will read movement
       into it. Conservation still applies: assets = liabilities + equity, and
       every figure must equal the matching row of the table below. #}
    {{ c.sankey(
        nodes=[("{{Cash and investments}}", "source"), ("{{Receivables}}", "source"),
               ("{{Property and equipment}}", "source"), ("{{Other assets}}", "source"),
               ("Total assets", "stage"),
               ("{{Payables}}", "cost"), ("{{Debt}}", "cost"),
               ("{{Other liabilities}}", "cost"),
               ("Shareholders&rsquo; equity", "retained")],
        links=[("{{Cash and investments}}", "Total assets", 40),
               ("{{Receivables}}", "Total assets", 20),
               ("{{Property and equipment}}", "Total assets", 15),
               ("{{Other assets}}", "Total assets", 25),
               ("Total assets", "{{Payables}}", 16),
               ("Total assets", "{{Debt}}", 23),
               ("Total assets", "{{Other liabilities}}", 33),
               ("Total assets", "Shareholders&rsquo; equity", 28)],
        height=380, label_room=190, unit="{{$ millions, at <date>}}",
        caption="{{Company}} — what it owns and who has a claim on it",
        note="{{one sentence: equity as a share of assets, and what funds the rest — a stock, not a flow}}") }}
    {# A profile with income and cash but no balance sheet is two thirds of a
       company. `balanced=true` renders the assets = liabilities + equity check;
       set it false only when the figures genuinely do not tie, and say why. #}
    {{ c.balance_sheet(periods=["{{prior}}", "{{latest}}"], unit="{{$M}}",
        caption="{{balance sheet — latest against the prior year end}}",
        check="{{assets = liabilities + equity}}",
        rows=[("Assets", ["", ""], "section", ""),
              ("{{Cash and investments}}", ["{{v}}", "{{v}}"], "detail", ""),
              ("Total assets", ["{{v}}", "{{v}}"], "subtotal", ""),
              ("Liabilities", ["", ""], "section", ""),
              ("{{Debt}}", ["{{v}}", "{{v}}"], "detail", ""),
              ("Total liabilities", ["{{v}}", "{{v}}"], "subtotal", ""),
              ("Equity", ["{{v}}", "{{v}}"], "total", "")],
        source="{{filing}}") }}
    {# A solvency score is standard, free and instantly readable. Show the
       INPUTS, not just the number — a score whose workings are hidden is an
       opinion wearing a decimal point. #}
    {{ c.composite_score(name="{{Altman Z}}", formula="{{the formula}}",
        inputs=[("{{component}}", "{{coef}}", "{{value}}", "{{contribution}}")],
        score="{{result}}", band="{{band}}", tone="good",
        bands=[("{{Distress}}", "{{&lt; 1.8}}", "bad"),
               ("{{Grey}}", "{{1.8–3.0}}", "neutral"),
               ("{{Safe}}", "{{&gt; 3.0}}", "good")],
        caption="{{solvency}}",
        note="{{what the score does and does not tell you about this company}}") }}
    {% call c.prose() %}{% raw %}{{liquidity, leverage, and what the balance sheet is actually FOR at this company — a fortress balance sheet and a levered one can both be deliberate}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("per-share", "Per share") %}
    {# The section most profiles omit, and the one that explains shareholder
       returns. A company can grow revenue slowly and per-share revenue quickly
       by retiring stock; the totals above never show it. #}
    {{ c.roll_forward(periods=["{{FY-4}}", "{{FY-3}}", "{{FY-2}}", "{{FY-1}}", "{{FY0}}"],
        caption="{{shares outstanding, weighted average}}", unit="{{millions}}",
        rows=[("Opening", ["{{v}}", "{{v}}", "{{v}}", "{{v}}", "{{v}}"], "opening"),
              ("{{Net retired}}", ["{{v}}", "{{v}}", "{{v}}", "{{v}}", "{{v}}"], "movement"),
              ("Closing", ["{{v}}", "{{v}}", "{{v}}", "{{v}}", "{{v}}"], "closing")],
        note="{{how much of the per-share growth was bought rather than earned}}") }}
    {{ c.metric_trend(
        periods=["{{FY-4}}", "{{FY-3}}", "{{FY-2}}", "{{FY-1}}", "{{FY0}}"],
        caption="{{per-share record}}",
        rows=[("Revenue per share", ["{{v}}", "{{v}}", "{{v}}", "{{v}}", "{{v}}"], "{{x%}}", "up"),
              ("Earnings per share", ["{{v}}", "{{v}}", "{{v}}", "{{v}}", "{{v}}"], "{{x%}}", "up"),
              ("Free cash flow per share", ["{{v}}", "{{v}}", "{{v}}", "{{v}}", "{{v}}"], "{{x%}}", "up"),
              ("Dividend per share", ["{{v}}", "{{v}}", "{{v}}", "{{v}}", "{{v}}"], "{{x%}}", "up")]) }}
    {% call c.prose() %}{% raw %}{{compare these growth rates with the totals above — the gap between them IS the buyback, and it is a return the income statement never shows}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("evolution", "How it evolved") %}
    {# Two trend tables, because they answer different questions: the first is
       where growth CAME FROM, the second whether spending discipline held. #}
    {{ c.metric_trend(
        periods=["{{FY-4}}", "{{FY-3}}", "{{FY-2}}", "{{FY-1}}", "{{FY0}}"],
        caption="{{revenue by segment, five fiscal years}}",
        rows=[("{{Segment A}}", ["{{v}}", "{{v}}", "{{v}}", "{{v}}", "{{v}}"], "{{x%}}", "up"),
              ("{{Segment B}}", ["{{v}}", "{{v}}", "{{v}}", "{{v}}", "{{v}}"], "{{x%}}", "down"),
              ("Total revenue", ["{{v}}", "{{v}}", "{{v}}", "{{v}}", "{{v}}"], "{{x%}}", "up")]) }}
    {# TOTALS BEFORE SHARES. This one shows the business getting bigger and
       which parts did it; the 100% chart that follows shows only the mix. Show
       them in this order — a reader who sees composition shift before seeing
       the total move cannot tell growth from substitution.
       In a stacked area only the BOTTOM band and the TOTAL are truly readable
       by eye; the middle bands are not, which is exactly why the normalised
       chart follows rather than replaces it. #}
    {{ c.stacked_area(
        categories=["{{FY-4}}", "{{FY-3}}", "{{FY-2}}", "{{FY-1}}", "{{FY0}}"],
        series=[("{{Segment A}}", [50, 52, 54, 56, 58]),
                ("{{Segment B}}", [30, 31, 33, 35, 37]),
                ("{{Segment C}}", [20, 20, 19, 19, 18])],
        caption="{{revenue by segment — total and composition}}", y_name="{{$M}}",
        note="{{one sentence: did the whole grow, and which band grew with it}}") }}
    {{ c.stacked_normalized(
        categories=["{{FY-4}}", "{{FY-3}}", "{{FY-2}}", "{{FY-1}}", "{{FY0}}"],
        series=[("{{Segment A}}", [50, 50, 50, 50, 50]),
                ("{{Segment B}}", [30, 30, 30, 30, 30]),
                ("{{Segment C}}", [20, 20, 20, 20, 20])],
        caption="{{revenue mix — each year as 100%}}",
        note="{{one sentence: is this the same business it was five years ago?}}") }}
    {# The bridge prices the mix shift: growth is rarely spread evenly, and one
       segment usually paid for all of it. Steps must carry start to end. #}
    {{ c.bridge(
        scale_min=0, scale_max=120,
        caption="{{revenue bridge, {{FY-4}} to {{FY0}} ({{unit}})}}",
        steps=[("{{FY-4}} revenue", 80, "start", "{{v}}"),
               ("{{Segment A}}", 25, "up", "{{+v}}"),
               ("{{Segment B}}", -8, "down", "{{-v}}"),
               ("{{FY0}} revenue", 100, "end", "{{v}}")],
        note="{{one sentence: which segment produced the growth, and what share of it}}") }}
    {{ c.metric_trend(
        periods=["{{FY-4}}", "{{FY-3}}", "{{FY-2}}", "{{FY-1}}", "{{FY0}}"],
        caption="{{margins and returns, five fiscal years}}",
        rows=[("Gross margin", ["{{pct}}", "{{pct}}", "{{pct}}", "{{pct}}", "{{pct}}"], "{{bps}}", "up"),
              ("R&amp;D / revenue", ["{{pct}}", "{{pct}}", "{{pct}}", "{{pct}}", "{{pct}}"], "{{bps}}", "up"),
              ("Operating margin", ["{{pct}}", "{{pct}}", "{{pct}}", "{{pct}}", "{{pct}}"], "{{bps}}", "up"),
              ("Return on invested capital", ["{{pct}}", "{{pct}}", "{{pct}}", "{{pct}}", "{{pct}}"], "{{bps}}", "up")]) }}
    {% call c.prose() %}{% raw %}{{what the two tables say together: whether growth came with operating leverage or bought it with spending}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("peers", "How it compares") %}
    {# A margin, a multiple or a return is meaningless alone. Name the peer set
       and say WHY those names — a peer group chosen by an API is not a peer
       group. Fiscal year ends rarely align; state the dates. #}
    {# `headers` lists the METRIC columns only — the macro emits the Company
       column itself. Passing it again shifts every value one column left and
       leaves the last one blank, which renders as a perfectly tidy wrong table. #}
    {{ c.peer_comparison(
        headers=["{{metric}}", "{{metric}}", "{{metric}}", "{{metric}}"],
        caption="{{peers — fiscal years ending on different dates}}",
        rows=[("{{Subject}}", ["{{v}}", "{{v}}", "{{v}}", "{{v}}"], true),
              ("{{Peer 1}}", ["{{v}}", "{{v}}", "{{v}}", "{{v}}"], false),
              ("{{Peer 2}}", ["{{v}}", "{{v}}", "{{v}}", "{{v}}"], false)]) }}
    {% call c.prose() %}{% raw %}{{where the subject is genuinely different from the group, and whether that difference is an advantage or a lag}}{% endraw %}{% endcall %}
  {% endcall %}
  {% call c.section("reading", "Reading") %}
    {% call c.callout("note") %}{% call c.prose() %}{% raw %}{{the four or five sentences a reader should leave with — the shape of the earnings, the spending, the balance sheet, and what changed. State what would change this reading.}}{% endraw %}{% endcall %}{% endcall %}
  {% endcall %}
{% endblock %}
