# Normalize all text files to LF in the repository and on checkout, on every
# platform. Stops the "LF will be replaced by CRLF" warnings and keeps the
# CDN-served CSS/JS/HTML byte-consistent across machines.
* text=auto eol=lf

# Explicit text types (composed into documents / served via jsDelivr).
*.css    text eol=lf
*.js     text eol=lf
*.html   text eol=lf
*.j2     text eol=lf
*.md     text eol=lf
*.py     text eol=lf
*.json   text eol=lf
*.svg    text eol=lf

# Binary types — never touch line endings.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.pdf    binary
